page { background: #f5f5f5; color: #1a1a1a; font-size: 14px; }
.btn-primary {
  background: #FFD000;
  color: #1a1a1a;
  border-radius: 25px;
  height: 50px;
  line-height: 50px;
  text-align: center;
  font-weight: bold;
}
.card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
