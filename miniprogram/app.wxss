/* 知行岛 · 设计 tokens（薄荷绿） */
page {
  --color-primary: #52B788;
  --color-primary-dark: #2D6A4F;
  --color-primary-light: #D8F3DC;
  --color-bg-page: #F4FAF6;
  --color-bg-card: #FFFFFF;
  --color-text: #1C2B20;
  --color-text-secondary: #8C9BA5;
  --color-disabled: #CFD8DC;
  --color-warning-bg: #FFF8E6;
  --color-warning-text: #8A6D3B;
  --radius-card: 32rpx;
  --radius-btn: 24rpx;
  --radius-chip: 40rpx;
  --shadow-card: 0 4rpx 24rpx rgba(28, 43, 32, 0.06);
  background: var(--color-bg-page);
  color: var(--color-text);
  font-size: 26rpx;
  line-height: 1.5;
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: var(--shadow-card);
}

.section-title {
  padding: 24rpx 32rpx 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary-dark);
}

.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: var(--radius-btn);
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-weight: 600;
  font-size: 30rpx;
  margin: 24rpx auto;
  width: 90%;
  box-shadow: 0 8rpx 20rpx rgba(82, 183, 136, 0.35);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-primary.disabled,
.btn-primary.disabled:active {
  background: var(--color-disabled);
  color: var(--color-text-secondary);
  box-shadow: none;
  opacity: 1;
  transform: none;
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-btn);
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 16rpx auto;
  width: 90%;
}

.chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-chip);
  font-size: 24rpx;
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
  background: transparent;
  margin-right: 16rpx;
}

.chip.active {
  background: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-chip);
  font-size: 22rpx;
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
}

.tag.gray {
  background: #ECEFF1;
  color: var(--color-text-secondary);
}

.empty {
  text-align: center;
  color: var(--color-text-secondary);
  padding: 80rpx 32rpx;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.label {
  margin: 24rpx 0 8rpx;
  font-weight: 600;
  font-size: 28rpx;
  color: var(--color-primary-dark);
}

.hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin: 16rpx 0;
  line-height: 1.6;
}

.picker-box {
  padding: 20rpx 24rpx;
  background: var(--color-bg-page);
  border-radius: 16rpx;
  color: var(--color-text);
  border: 2rpx solid var(--color-primary-light);
}

.page-safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.fixed-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-card);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(28, 43, 32, 0.08);
  z-index: 100;
}

.fixed-bottom-spacer {
  height: 180rpx;
}
