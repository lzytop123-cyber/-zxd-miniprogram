.plan-canvas {
  position: absolute;
  inset: 0;
  background: #fff;
  overflow: hidden;
}

/* 缩放/拖动容器 */
.plan-area {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.plan-move {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 底图随 movable-view 一起缩放 */
.plan-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.seats-layer {
  position: absolute;
  inset: 0;
  z-index: 10;
}

/* 缩放控制条 */
.zoom-bar {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  z-index: 30;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: stretch;
}

.zoom-btn {
  min-width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 12rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #2d6a4f;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid #d8f3dc;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(45, 106, 79, 0.12);
}

.zoom-reset {
  font-size: 22rpx;
  font-weight: 600;
}

/* 命中区域略大于编号框，覆盖上下桌线，便于点选（相对裁切图 843×647） */
.seat-anchor {
  position: absolute;
  transform: translate(-50%, -50%);
  width: 6.6%;
  height: 7.2%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 编号框：与原图 ~54×44px 编号框对齐 */
.seat-cell {
  width: 94%;
  height: 82%;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.12s ease;
}

/* 可选：保持原图清爽外观，仅极淡提示可点 */
.seat-cell.available {
  background: rgba(82, 183, 136, 0.08);
}

/* 已约 */
.seat-cell.reserved {
  background: rgba(230, 162, 60, 0.34);
}

/* 使用中 */
.seat-cell.occupied {
  background: rgba(120, 130, 140, 0.42);
}

/* 平面图有框但当前不可订 */
.seat-cell.empty {
  background: rgba(180, 188, 196, 0.40);
}

/* 选中：实心绿 + 白字 */
.seat-cell.is-selected {
  background: #52b788;
  border: 2rpx solid #2d6a4f;
  box-shadow: 0 0 0 4rpx rgba(82, 183, 136, 0.35);
}

.seat-cell-num {
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}
