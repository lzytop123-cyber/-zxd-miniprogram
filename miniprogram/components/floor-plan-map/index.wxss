.plan-canvas {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  background: #fff;
}

.plan-title {
  flex-shrink: 0;
  text-align: center;
  padding: 6rpx 0 4rpx;
  border-bottom: 2rpx solid #e5e7eb;
}

.plan-title-main {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
  letter-spacing: 2rpx;
}

.plan-title-sub {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-top: 2rpx;
}

.plan-frame {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  border: 4rpx solid #374151;
  border-top: none;
  box-sizing: border-box;
}

/* 主区 772/990 = 78.99% */
.plan-main {
  position: relative;
  flex: 0 0 78.99%;
  height: 78.99%;
  background: #fff;
  overflow: hidden;
}

.wall-outer {
  position: absolute;
  inset: 0;
  border: 4rpx solid #374151;
  box-sizing: border-box;
  pointer-events: none;
  z-index: 1;
}

/* 横向走廊 545/772 = 70.59% */
.wall-h {
  position: absolute;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #374151;
  z-index: 2;
  pointer-events: none;
}

.hall-divider {
  top: 70.59%;
}

/* 纵向墙 370/1024=36.13%, 598/1024=58.40%, 600/1024=58.59% */
.wall-v {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: #374151;
  z-index: 2;
  pointer-events: none;
}

.wall-v1 {
  left: 36.13%;
  bottom: 29.41%;
}

.wall-v2 {
  left: 58.40%;
  bottom: 29.41%;
}

.wall-v3 {
  left: 58.59%;
  top: 0;
  bottom: 0;
}

.fill-standard {
  position: absolute;
  left: 58.59%;
  top: 0;
  right: 0;
  bottom: 0;
  background: #f0faf4;
  z-index: 0;
}

.zone-label {
  position: absolute;
  font-size: 18rpx;
  color: #9ca3af;
  font-weight: 600;
  z-index: 3;
  pointer-events: none;
}

.z-imm-left { left: 3%; top: 2%; }
.z-imm-mid { left: 38%; top: 2%; }
.z-imm-low { left: 3%; top: 72%; }
.z-wc {
  left: 42%;
  top: 78%;
  font-size: 22rpx;
  color: #6b7280;
}
.z-std { left: 61%; top: 2%; color: #52b788; }

.rest-dash {
  position: absolute;
  border: 2rpx dashed #9ca3af;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #9ca3af;
  z-index: 2;
  pointer-events: none;
}

.rest-imm-low {
  left: 38%;
  top: 73%;
  width: 19%;
  height: 24%;
}

.door {
  position: absolute;
  z-index: 4;
  pointer-events: none;
}

.door-imm-left {
  left: 34.5%;
  top: 58%;
  width: 18rpx;
  height: 18rpx;
  border-right: 3rpx solid #374151;
  border-bottom: 3rpx solid #374151;
  border-radius: 0 0 18rpx 0;
}

.door-imm-mid {
  left: 46%;
  top: 68%;
  width: 26rpx;
  height: 14rpx;
  border-left: 3rpx solid #374151;
  border-right: 3rpx solid #374151;
  border-bottom: 3rpx solid #374151;
  border-radius: 0 0 13rpx 13rpx;
}

.door-imm-low {
  left: 34.5%;
  top: 71%;
  width: 18rpx;
  height: 18rpx;
  border-right: 3rpx solid #374151;
  border-top: 3rpx solid #374151;
  border-radius: 0 18rpx 0 0;
}

.door-std {
  left: 66%;
  top: 86%;
  width: 34rpx;
  height: 16rpx;
  border-left: 3rpx solid #374151;
  border-right: 3rpx solid #374151;
  border-bottom: 3rpx solid #374151;
  border-radius: 0 0 16rpx 16rpx;
}

.seats-layer {
  position: absolute;
  inset: 0;
  z-index: 10;
}

.seat-anchor {
  position: absolute;
  transform: translate(-50%, -50%);
}

.seat-unit {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.seat-line {
  width: 34rpx;
  height: 3rpx;
  background: #374151;
}

.seat-num {
  width: 42rpx;
  height: 38rpx;
  line-height: 38rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #1f2937;
  background: #fff;
  border: 2rpx solid #374151;
  border-radius: 10rpx;
  margin: 3rpx 0;
  box-sizing: border-box;
}

.seat-unit.reserved .seat-num {
  background: #fff8e6;
  border-color: #e6a23c;
  color: #8a6d3b;
}

.seat-unit.occupied .seat-num {
  background: #e5e7eb;
  border-color: #9ca3af;
  color: #6b7280;
}

.seat-unit.empty .seat-num {
  background: #f9fafb;
  border-color: #d1d5db;
  color: #d1d5db;
}

.seat-unit.empty .seat-line {
  background: #d1d5db;
}

.seat-unit.is-selected .seat-num {
  background: #52b788;
  border-color: #2d6a4f;
  color: #fff;
  box-shadow: 0 0 0 4rpx rgba(82, 183, 136, 0.4);
}

/* 底栏 218/990 = 22.02% */
.plan-footer {
  flex: 0 0 22.02%;
  height: 22.02%;
  display: flex;
  border-top: 4rpx solid #374151;
}

.fac {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 3rpx solid #374151;
  background: #f9fafb;
  font-size: 18rpx;
  color: #6b7280;
  font-weight: 600;
  box-sizing: border-box;
}

.fac-rest { width: 16.41%; }
.fac-wc { width: 16.41%; }

.fac-split {
  width: 36.72%;
  display: flex;
  border-right: 3rpx solid #374151;
}

.fac-tea,
.fac-dine {
  flex: 1;
  border-right: 2rpx dashed #9ca3af;
}

.fac-dine {
  border-right: none;
}

.fac-entry {
  flex: 1;
  background: #f0faf4;
  color: #2d6a4f;
  font-weight: 700;
  font-size: 20rpx;
}

.entry-doors {
  margin-top: 6rpx;
  width: 40rpx;
  height: 20rpx;
  border-left: 3rpx solid #374151;
  border-right: 3rpx solid #374151;
  border-bottom: 3rpx solid #374151;
  border-radius: 0 0 10rpx 10rpx;
}
