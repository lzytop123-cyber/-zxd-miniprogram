.plan-canvas {
  position: absolute;
  inset: 0;
  overflow: hidden;
  background: linear-gradient(180deg, #f6fbf7 0%, #eef7f1 100%);
  --wall: rgba(74, 92, 82, 0.92);
  --wall-soft: rgba(74, 92, 82, 0.62);
  --desk: rgba(116, 136, 124, 0.55);
  --tint-imm: rgba(82, 183, 136, 0.05);
  --tint-std: rgba(82, 183, 136, 0.09);
  --tint-svc: rgba(110, 132, 120, 0.05);
  --dash: rgba(96, 140, 112, 0.5);
  --label: rgba(58, 80, 66, 0.62);
}

.plan-area {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.plan-move {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 0~900 (x) / 0~700 (y) 逻辑画布映射到此盒子 */
.floor {
  position: absolute;
  inset: 0;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdfc 0%, #f3f9f5 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  overflow: hidden;
}

/* ============ 区域底色 ============ */
.room {
  position: absolute;
  border-radius: 12rpx;
}

.room--a {
  left: 5.333%;
  top: 6.286%;
  width: 26.667%;
  height: 42.286%;
  background: var(--tint-imm);
}

.room--b {
  left: 32%;
  top: 6.286%;
  width: 26.667%;
  height: 42.286%;
  background: var(--tint-imm);
}

.room--c {
  left: 58.667%;
  top: 6.286%;
  width: 36%;
  height: 59.429%;
  background: var(--tint-std);
}

.room--d {
  left: 5.333%;
  top: 55.429%;
  width: 16.889%;
  height: 33.857%;
  background: var(--tint-imm);
}

/* ============ 服务区（实线围合） ============ */
.svc {
  position: absolute;
  box-sizing: border-box;
  border: 5rpx solid var(--wall-soft);
  background: var(--tint-svc);
  border-radius: 6rpx;
}

.svc--wc {
  left: 40%;
  top: 58.286%;
  width: 22.222%;
  height: 28.143%;
}

.svc--strip {
  left: 33.333%;
  top: 86.429%;
  width: 31.111%;
  height: 7.286%;
}

.strip-split {
  position: absolute;
  left: 48.889%;
  top: 86.429%;
  height: 7.286%;
  border-left: 3rpx dashed var(--dash);
}

/* ============ 休息区（虚线围合） ============ */
.rest {
  position: absolute;
  box-sizing: border-box;
  left: 22.222%;
  top: 67.143%;
  width: 17.778%;
  height: 19.286%;
  border: 3rpx dashed var(--dash);
  border-radius: 8rpx;
}

/* ============ 墙体 ============ */
.wall {
  position: absolute;
  background: var(--wall);
  border-radius: 4rpx;
}

.wall--top {
  left: 5.333%;
  right: 5.333%;
  top: 6.286%;
  height: 7rpx;
}

.wall--left {
  left: 5.333%;
  top: 6.286%;
  bottom: 6.286%;
  width: 7rpx;
}

.wall--right {
  right: 5.333%;
  top: 6.286%;
  bottom: 6.286%;
  width: 7rpx;
}

.wall--bottom-l {
  left: 5.333%;
  width: 61.333%;
  bottom: 6.286%;
  height: 7rpx;
}

.wall--bottom-r {
  left: 78.444%;
  right: 5.333%;
  bottom: 6.286%;
  height: 7rpx;
}

.wall--jamb-l {
  left: 66.667%;
  top: 87.143%;
  height: 6.571%;
  width: 7rpx;
}

.wall--jamb-r {
  left: 78.444%;
  top: 87.143%;
  height: 6.571%;
  width: 7rpx;
}

.wall--v1 {
  left: 32%;
  top: 6.286%;
  height: 42.286%;
  width: 6rpx;
}

.wall--v2 {
  left: 58.667%;
  top: 6.286%;
  height: 59.429%;
  width: 6rpx;
}

.wall--corr1 {
  left: 5.333%;
  width: 12.444%;
  top: 48.571%;
  height: 6rpx;
}

.wall--corr2 {
  left: 26.222%;
  width: 18.667%;
  top: 48.571%;
  height: 6rpx;
}

.wall--corr3 {
  left: 53.333%;
  width: 5.333%;
  top: 48.571%;
  height: 6rpx;
}

/* ============ 门弧 ============ */
.door {
  position: absolute;
  box-sizing: border-box;
  border: 3rpx solid var(--wall-soft);
  border-top-color: transparent;
  border-right-color: transparent;
  border-bottom-left-radius: 100%;
}

.door--a {
  left: 17.778%;
  top: 48.571%;
  width: 8.444%;
  height: 9.143%;
}

.door--b {
  left: 44.889%;
  top: 48.571%;
  width: 8.444%;
  height: 9.143%;
}

.door--wc {
  left: 42.222%;
  top: 50.857%;
  width: 6.5%;
  height: 7.4%;
  border-top-color: var(--wall-soft);
  border-right-color: var(--wall-soft);
  border-bottom-color: transparent;
  border-left-color: transparent;
  border-bottom-left-radius: 0;
  border-top-left-radius: 100%;
}

.door--entry-l {
  left: 66.667%;
  bottom: 6.286%;
  width: 5.889%;
  height: 7%;
  border-top-color: var(--wall-soft);
  border-right-color: transparent;
  border-bottom-color: transparent;
  border-left-color: var(--wall-soft);
  border-bottom-left-radius: 0;
  border-top-left-radius: 100%;
}

.door--entry-r {
  left: 72.556%;
  bottom: 6.286%;
  width: 5.889%;
  height: 7%;
  border-top-color: var(--wall-soft);
  border-left-color: transparent;
  border-bottom-color: transparent;
  border-right-color: var(--wall-soft);
  border-bottom-left-radius: 0;
  border-top-right-radius: 100%;
}

/* ============ 文字标签 ============ */
.lbl {
  position: absolute;
  transform: translate(-50%, -50%);
  white-space: nowrap;
  color: var(--label);
  letter-spacing: 1rpx;
  pointer-events: none;
}

.lbl--zone {
  font-size: 15rpx;
  font-weight: 600;
}

.lbl--svc {
  font-size: 13rpx;
}

.lbl--za {
  left: 18.667%;
  top: 29.286%;
}

.lbl--zb {
  left: 45.556%;
  top: 29.286%;
}

.lbl--zc {
  left: 76.667%;
  top: 47.143%;
}

.lbl--zd {
  left: 16.667%;
  top: 72.143%;
}

.lbl--wc {
  left: 51.111%;
  top: 71.429%;
}

.lbl--rest {
  left: 31.111%;
  top: 77.143%;
}

.lbl--tea {
  left: 41.111%;
  top: 90%;
}

.lbl--dine {
  left: 56.111%;
  top: 90%;
}

.lbl--entry {
  left: 72.556%;
  top: 90.286%;
  font-size: 14rpx;
  font-weight: 600;
  color: rgba(58, 80, 66, 0.78);
}

/* ============ 座位层 ============ */
.seats-layer {
  position: absolute;
  inset: 0;
  z-index: 8;
}

.seat-anchor {
  position: absolute;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.seat-unit {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
}

.orient-v .seat-unit {
  flex-direction: column;
}

.orient-h .seat-unit {
  flex-direction: row;
}

.desk-bar {
  flex-shrink: 0;
  border-radius: 3rpx;
  background: var(--desk);
}

.orient-v .desk-bar {
  width: 30rpx;
  height: 5rpx;
}

.orient-h .desk-bar {
  width: 5rpx;
  height: 28rpx;
}

.seat-chip {
  width: 38rpx;
  height: 28rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(111, 125, 115, 0.2);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 3rpx 8rpx rgba(70, 86, 76, 0.08);
  transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
}

.seat-chip.available {
  border-color: rgba(78, 146, 104, 0.28);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(237, 246, 239, 0.96));
}

.seat-anchor:active .seat-chip.available {
  transform: scale(1.08);
  border-color: rgba(64, 137, 93, 0.5);
  box-shadow: 0 0 0 4rpx rgba(85, 157, 113, 0.12), 0 6rpx 14rpx rgba(70, 86, 76, 0.1);
}

.seat-chip.reserved {
  background: rgba(237, 224, 192, 0.92);
  border-color: rgba(181, 148, 75, 0.46);
}

.seat-chip.occupied {
  background: rgba(201, 208, 203, 0.92);
  border-color: rgba(121, 133, 126, 0.46);
}

.seat-chip.is-selected {
  background: linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(226, 242, 232, 1));
  border: 3rpx solid #2d6a4f;
  box-shadow: 0 0 0 5rpx rgba(84, 179, 129, 0.18);
  transform: scale(1.12);
}

.seat-chip-label {
  font-size: 14rpx;
  font-weight: 700;
  color: #2d6a4f;
  line-height: 1;
  pointer-events: none;
}

.seat-chip-label--active {
  color: #1b4332;
}
