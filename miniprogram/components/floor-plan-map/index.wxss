.plan-canvas {
  position: absolute;
  inset: 0;
  overflow: hidden;
  background: linear-gradient(180deg, #f6fbf7 0%, #eef7f1 100%);
  --wall: rgba(74, 92, 82, 0.92);
  --wall-soft: rgba(74, 92, 82, 0.62);
  --desk: rgba(116, 136, 124, 0.55);
  --tint-imm: rgba(82, 183, 136, 0.05);
  --tint-std: rgba(82, 183, 136, 0.09);
  --tint-svc: rgba(110, 132, 120, 0.05);
  --dash: rgba(96, 140, 112, 0.5);
  --label: rgba(58, 80, 66, 0.62);
}

.plan-area {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.plan-move {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 0~900 (x) / 0~700 (y) 逻辑画布映射到此盒子 */
.floor {
  position: absolute;
  inset: 0;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdfc 0%, #f3f9f5 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  overflow: hidden;
}

/* ============ 区域底色 ============ */
.room {
  position: absolute;
  border-radius: 10rpx;
}

.room--a {
  left: 5.333%;
  top: 6.286%;
  width: 27.41%;
  height: 40.04%;
  background: var(--tint-imm);
}

.room--b {
  left: 32.74%;
  top: 6.286%;
  width: 27.95%;
  height: 40.04%;
  background: var(--tint-imm);
}

.room--c {
  left: 60.69%;
  top: 6.286%;
  width: 33.98%;
  height: 66.2%;
  background: var(--tint-std);
}

.room--d {
  left: 5.333%;
  top: 53.4%;
  width: 27.41%;
  height: 40.32%;
  background: var(--tint-imm);
}

/* ============ 服务区（实线围合） ============ */
.svc {
  position: absolute;
  box-sizing: border-box;
  border: 5rpx solid var(--wall-soft);
  background: rgba(255, 255, 255, 0.55);
  border-radius: 4rpx;
}

.svc--wc {
  left: 32.74%;
  top: 53.4%;
  width: 27.95%;
  height: 30.41%;
}

.svc--strip {
  left: 32.74%;
  top: 83.81%;
  width: 27.95%;
  height: 9.91%;
}

.strip-split {
  position: absolute;
  left: 46.98%;
  top: 83.81%;
  height: 9.91%;
  border-left: 3rpx dashed var(--dash);
}

/* ============ 休息区（虚线围合） ============ */
.rest {
  position: absolute;
  box-sizing: border-box;
  left: 19.03%;
  top: 61.18%;
  width: 13.71%;
  height: 22.63%;
  border: 3rpx dashed var(--dash);
  border-radius: 6rpx;
}

/* ============ 1、2 号座位间 ============ */
.niche {
  position: absolute;
  box-sizing: border-box;
  left: 78.23%;
  top: 72.49%;
  width: 14.79%;
  height: 10.62%;
  border: 4rpx solid var(--wall-soft);
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.5);
}

/* ============ 墙体 ============ */
.wall {
  position: absolute;
  background: var(--wall);
  border-radius: 4rpx;
}

.wall--top {
  left: 5.333%;
  right: 5.333%;
  top: 6.286%;
  height: 7rpx;
}

.wall--left {
  left: 5.333%;
  top: 6.286%;
  bottom: 6.286%;
  width: 7rpx;
}

.wall--right {
  right: 5.333%;
  top: 6.286%;
  height: 78.94%;
  width: 7rpx;
}

.wall--bottom-l {
  left: 5.333%;
  width: 56.46%;
  bottom: 6.286%;
  height: 7rpx;
}

.wall--bottom-r {
  left: 73.84%;
  right: 5.333%;
  top: 85.23%;
  height: 7rpx;
}

.wall--notch-jamb {
  left: 73.84%;
  top: 85.23%;
  height: 8.49%;
  width: 7rpx;
}

/* 竖向隔墙：在走廊处断开 */
.wall--v1-top {
  left: 32.74%;
  top: 6.286%;
  height: 40.04%;
  width: 6rpx;
}

.wall--v1-bot {
  left: 32.74%;
  top: 53.4%;
  height: 40.32%;
  width: 6rpx;
}

.wall--v2-top {
  left: 60.69%;
  top: 6.286%;
  height: 40.04%;
  width: 6rpx;
}

.wall--v2-bot {
  left: 60.69%;
  top: 53.4%;
  height: 40.32%;
  width: 6rpx;
}

/* 走廊上横墙（room A/B 底，留 A、B 门洞） */
.wall--ct1 {
  left: 5.333%;
  width: 19.19%;
  top: 46.33%;
  height: 6rpx;
}

.wall--ct2 {
  left: 33.29%;
  width: 14.24%;
  top: 46.33%;
  height: 6rpx;
}

.wall--ct3 {
  left: 56.31%;
  width: 4.38%;
  top: 46.33%;
  height: 6rpx;
}

/* 走廊下横墙（下方房间顶，留沉浸区、卫生间门洞） */
.wall--cb1 {
  left: 5.333%;
  width: 15.89%;
  top: 53.4%;
  height: 6rpx;
}

.wall--cb2 {
  left: 29.99%;
  width: 10.97%;
  top: 53.4%;
  height: 6rpx;
}

.wall--cb3 {
  left: 49.73%;
  width: 10.96%;
  top: 53.4%;
  height: 6rpx;
}

/* ============ 门弧 ============ */
.door {
  position: absolute;
  box-sizing: border-box;
  border: 3rpx solid var(--wall-soft);
}

.door--down {
  border-top-color: transparent;
  border-right-color: transparent;
  border-bottom-left-radius: 100%;
}

.door--up-l {
  border-bottom-color: transparent;
  border-right-color: transparent;
  border-top-left-radius: 100%;
}

.door--up-r {
  border-bottom-color: transparent;
  border-left-color: transparent;
  border-top-right-radius: 100%;
}

.door--a {
  left: 24.52%;
  top: 46.33%;
  width: 8.77%;
  height: 8.49%;
}

.door--b {
  left: 47.53%;
  top: 46.33%;
  width: 8.77%;
  height: 8.49%;
}

.door--d {
  left: 21.22%;
  top: 53.4%;
  width: 8.77%;
  height: 8.49%;
}

.door--wc {
  left: 40.96%;
  top: 53.4%;
  width: 8.77%;
  height: 8.49%;
}

.door--entry-l {
  left: 61.79%;
  bottom: 6.286%;
  width: 6.03%;
  height: 7%;
}

.door--entry-r {
  left: 67.81%;
  bottom: 6.286%;
  width: 6.03%;
  height: 7%;
}

/* ============ 文字标签 ============ */
.lbl {
  position: absolute;
  transform: translate(-50%, -50%);
  white-space: nowrap;
  color: var(--label);
  letter-spacing: 1rpx;
  pointer-events: none;
}

.lbl--zone {
  font-size: 15rpx;
  font-weight: 600;
}

.lbl--svc {
  font-size: 13rpx;
}

.lbl--za {
  left: 19.58%;
  top: 22.98%;
}

.lbl--zb {
  left: 48.08%;
  top: 22.98%;
}

.lbl--zc {
  left: 77.13%;
  top: 47.74%;
}

.lbl--zd {
  left: 16.84%;
  top: 66%;
}

.lbl--wc {
  left: 46.7%;
  top: 68.6%;
}

.lbl--rest {
  left: 25.9%;
  top: 72%;
}

.lbl--tea {
  left: 39.86%;
  top: 88.8%;
}

.lbl--dine {
  left: 53.84%;
  top: 88.8%;
}

.lbl--entry {
  left: 66.5%;
  top: 86%;
  font-size: 14rpx;
  font-weight: 600;
  color: rgba(58, 80, 66, 0.78);
}

/* ============ 座位层 ============ */
.seats-layer {
  position: absolute;
  inset: 0;
  z-index: 8;
}

.seat-anchor {
  position: absolute;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.seat-unit {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
}

.orient-v .seat-unit {
  flex-direction: column;
}

.orient-h .seat-unit {
  flex-direction: row;
}

.desk-bar {
  flex-shrink: 0;
  border-radius: 3rpx;
  background: var(--desk);
}

.orient-v .desk-bar {
  width: 30rpx;
  height: 5rpx;
}

.orient-h .desk-bar {
  width: 5rpx;
  height: 28rpx;
}

.seat-chip {
  width: 38rpx;
  height: 28rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(111, 125, 115, 0.2);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 3rpx 8rpx rgba(70, 86, 76, 0.08);
  transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
}

.seat-chip.available {
  border-color: rgba(78, 146, 104, 0.28);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(237, 246, 239, 0.96));
}

.seat-anchor:active .seat-chip.available {
  transform: scale(1.08);
  border-color: rgba(64, 137, 93, 0.5);
  box-shadow: 0 0 0 4rpx rgba(85, 157, 113, 0.12), 0 6rpx 14rpx rgba(70, 86, 76, 0.1);
}

.seat-chip.reserved {
  background: rgba(237, 224, 192, 0.92);
  border-color: rgba(181, 148, 75, 0.46);
}

.seat-chip.occupied {
  background: rgba(201, 208, 203, 0.92);
  border-color: rgba(121, 133, 126, 0.46);
}

.seat-chip.is-selected {
  background: linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(226, 242, 232, 1));
  border: 3rpx solid #2d6a4f;
  box-shadow: 0 0 0 5rpx rgba(84, 179, 129, 0.18);
  transform: scale(1.12);
}

.seat-chip-label {
  font-size: 14rpx;
  font-weight: 700;
  color: #2d6a4f;
  line-height: 1;
  pointer-events: none;
}

.seat-chip-label--active {
  color: #1b4332;
}
