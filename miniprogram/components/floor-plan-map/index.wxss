.plan-canvas {
  position: absolute;
  inset: 0;
  overflow: hidden;
  background: linear-gradient(180deg, #f6fbf7 0%, #eef7f1 100%);
}

.plan-area {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.plan-move {
  width: 100%;
  height: 100%;
  position: relative;
}

.floor-plate {
  position: absolute;
  inset: 3.4% 3.4%;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 251, 248, 0.98));
  box-shadow:
    0 16rpx 42rpx rgba(61, 101, 78, 0.09),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
  overflow: hidden;
}

.floor-border {
  position: absolute;
  inset: 2.2%;
  border: 2rpx solid rgba(110, 125, 117, 0.16);
  border-radius: 24rpx;
  pointer-events: none;
}

.wall {
  position: absolute;
  background: #6d766f;
  border-radius: 999rpx;
  opacity: 0.92;
  pointer-events: none;
}

.wall--top {
  left: 5.4%;
  right: 5.4%;
  top: 5.5%;
  height: 6rpx;
}

.wall--left {
  left: 5.6%;
  top: 5.5%;
  bottom: 5.5%;
  width: 6rpx;
}

.wall--right {
  right: 5.6%;
  top: 5.5%;
  bottom: 5.5%;
  width: 6rpx;
}

.wall--bottom {
  left: 5.4%;
  right: 5.4%;
  bottom: 5.5%;
  height: 6rpx;
}

.zone {
  position: absolute;
  border-radius: 18rpx;
  background: rgba(75, 150, 107, 0.035);
  border: 1rpx solid rgba(75, 150, 107, 0.08);
}

.zone-label {
  position: absolute;
  color: rgba(57, 78, 65, 0.56);
  font-size: 13rpx;
  letter-spacing: 1rpx;
}

.zone--immersive {
  width: 18.5%;
  height: 33%;
}

.zone--left-top {
  left: 6.9%;
  top: 8.3%;
}

.zone--left-bottom {
  left: 6.9%;
  top: 56.1%;
  height: 18.5%;
}

.zone--work {
  left: 34.2%;
  top: 8.8%;
  width: 17.0%;
  height: 30.6%;
}

.zone--standard {
  right: 7.1%;
  top: 8.8%;
  width: 25.0%;
  height: 56.2%;
}

.zone--service {
  background: rgba(75, 150, 107, 0.03);
  border-style: dashed;
}

.zone--middle-bottom {
  left: 40.4%;
  bottom: 20.3%;
  width: 21.0%;
  height: 10%;
}

.zone--bottom-left {
  left: 22.0%;
  bottom: 27.5%;
  width: 15.6%;
  height: 10%;
}

.zone--bottom-right {
  left: 67.4%;
  bottom: 20.0%;
  width: 15.6%;
  height: 10%;
}

.zone--rest-center {
  left: 38.4%;
  bottom: 17.5%;
  width: 23.0%;
  height: 8.8%;
}

.zone-label--left-top {
  left: 15.3%;
  top: 24.8%;
}

.zone-label--left-bottom {
  left: 15.3%;
  top: 68.0%;
}

.zone-label--center-top {
  left: 40.9%;
  top: 22.0%;
}

.zone-label--right {
  right: 16.1%;
  top: 34.4%;
}

.zone-label--service {
  left: 46.2%;
  bottom: 15.6%;
}

.divider {
  position: absolute;
  background: #6d766f;
  border-radius: 999rpx;
  opacity: 0.88;
  pointer-events: none;
}

.divider--vertical-left {
  left: 30.5%;
  top: 8.0%;
  width: 6rpx;
  height: 33.8%;
}

.divider--vertical-middle {
  left: 59.2%;
  top: 8.0%;
  width: 6rpx;
  height: 56.4%;
}

.divider--horizontal-upper {
  left: 14.9%;
  top: 40.6%;
  width: 43.2%;
  height: 6rpx;
}

.divider--horizontal-middle {
  left: 34.1%;
  bottom: 29.0%;
  width: 28.8%;
  height: 6rpx;
}

.divider--entry-notched {
  left: 50.7%;
  bottom: 7.3%;
  width: 5.8%;
  height: 7.4%;
  border-left: 6rpx solid #6d766f;
  border-bottom: 6rpx solid #6d766f;
  border-radius: 0 0 0 18rpx;
  background: transparent;
}

.arch {
  position: absolute;
  border: 2rpx solid #6d766f;
  border-top-color: transparent;
  border-radius: 0 0 40rpx 40rpx;
  background: transparent;
  opacity: 0.92;
  pointer-events: none;
}

.arch--left {
  left: 12.5%;
  top: 39.5%;
  width: 5.8%;
  height: 5.8%;
  border-right-color: transparent;
}

.arch--middle {
  left: 43.4%;
  top: 39.5%;
  width: 5.8%;
  height: 5.8%;
  border-right-color: transparent;
}

.arch--entry {
  left: 58.6%;
  bottom: 5.5%;
  width: 4.8%;
  height: 6.6%;
  border-right-color: transparent;
}

.small-label {
  position: absolute;
  font-size: 12rpx;
  color: rgba(76, 92, 84, 0.72);
}

.small-label--entry {
  left: 54.2%;
  bottom: 3.6%;
}

.small-label--service {
  left: 49.4%;
  bottom: 7.8%;
}

.seats-layer {
  position: absolute;
  inset: 0;
  z-index: 8;
}

.seat-anchor {
  position: absolute;
  transform: translate(-50%, -50%);
  width: 5.6%;
  height: 6.1%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.seat-chip {
  width: 92%;
  height: 80%;
  border-radius: 12rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(111, 125, 115, 0.18);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 10rpx rgba(70, 86, 76, 0.07);
  transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
}

.seat-chip.available {
  border-color: rgba(78, 146, 104, 0.16);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(237, 246, 239, 0.96));
}

.seat-anchor:active .seat-chip.available {
  transform: scale(1.05);
  border-color: rgba(64, 137, 93, 0.46);
  box-shadow: 0 0 0 4rpx rgba(85, 157, 113, 0.1), 0 8rpx 16rpx rgba(70, 86, 76, 0.08);
}

.seat-chip.reserved {
  background: rgba(237, 224, 192, 0.92);
  border-color: rgba(181, 148, 75, 0.44);
}

.seat-chip.occupied {
  background: rgba(201, 208, 203, 0.92);
  border-color: rgba(121, 133, 126, 0.44);
}

.seat-chip.empty {
  display: none;
}

.seat-chip.is-selected {
  background: linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(226, 242, 232, 1));
  border: 3rpx solid #4b956b;
  box-shadow: 0 0 0 5rpx rgba(84, 179, 129, 0.16);
  transform: scale(1.08);
}

.seat-chip-label {
  font-size: 12rpx;
  font-weight: 700;
  color: #315241;
  line-height: 1;
  pointer-events: none;
}

.seat-chip-label--active {
  color: #214232;
}
