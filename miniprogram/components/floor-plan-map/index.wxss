.plan-canvas {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, #F4FAF6 0%, #EAF7EF 100%);
  overflow: hidden;
}

.plan-area {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.plan-move {
  width: 100%;
  height: 100%;
  position: relative;
}

.plan-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.seats-layer {
  position: absolute;
  inset: 0;
  z-index: 10;
}

.zoom-bar {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  z-index: 30;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.zoom-btn {
  min-width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 10rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #2d6a4f;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid #d8f3dc;
  border-radius: 14rpx;
  box-shadow: 0 4rpx 12rpx rgba(45, 106, 79, 0.12);
}

.zoom-reset {
  font-size: 20rpx;
  font-weight: 700;
}

.seat-anchor {
  position: absolute;
  transform: translate(-50%, -50%);
  width: 6.6%;
  height: 7.2%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.seat-cell {
  width: 94%;
  height: 82%;
  border-radius: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  background: transparent;
  transition: transform 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease;
}

.seat-cell.is-hidden {
  opacity: 0;
  pointer-events: none;
}

/* 可选：轻边框，不遮挡底图编号 */
.seat-cell.available {
  border-color: rgba(82, 183, 136, 0.55);
  background: rgba(255, 255, 255, 0.08);
}

.seat-anchor:active .seat-cell.available {
  transform: scale(1.08);
  border-color: #52b788;
  background: rgba(82, 183, 136, 0.16);
  box-shadow: 0 0 0 4rpx rgba(82, 183, 136, 0.22);
}

.seat-cell.reserved {
  background: rgba(255, 193, 94, 0.28);
  border-color: rgba(201, 162, 39, 0.7);
}

.seat-cell.occupied {
  background: rgba(45, 106, 79, 0.2);
  border-color: rgba(45, 106, 79, 0.45);
}

.seat-cell.empty {
  display: none;
}

/* 已选：描边高亮，保留底图编号可见 */
.seat-cell.is-selected {
  background: rgba(82, 183, 136, 0.22);
  border: 3rpx solid #2d6a4f;
  box-shadow:
    0 0 0 5rpx rgba(82, 183, 136, 0.32),
    0 4rpx 12rpx rgba(45, 106, 79, 0.2);
  transform: scale(1.06);
}

.seat-cell-num {
  font-size: 17rpx;
  font-weight: 800;
  color: #2d6a4f;
  line-height: 1;
  text-shadow: 0 0 4rpx rgba(255, 255, 255, 0.95);
  pointer-events: none;
}

.seat-cell-num--on {
  color: #1b4332;
  font-size: 18rpx;
}

.seat-cell-num--dim {
  color: rgba(28, 43, 32, 0.45);
}
