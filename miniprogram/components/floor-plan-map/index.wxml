<template name="seatUnit">
  <view
    class="seat-unit {{seat.status}} {{selectedId===seat.id?'is-selected':''}}"
    bindtap="onTap"
    data-id="{{seat.id}}"
    data-code="{{seat.seat_code}}"
    data-status="{{seat.status}}"
  >
    <view class="seat-line"></view>
    <view class="seat-num">{{seat.map_label}}</view>
    <view class="seat-line"></view>
  </view>
</template>

<view class="plan-canvas">
  <view class="plan-title">
    <text class="plan-title-main">知行岛 · 自习室</text>
    <text class="plan-title-sub">座位平面图</text>
  </view>

  <view class="plan-frame">
    <view class="plan-main">
      <!-- 外墙 -->
      <view class="wall-outer"></view>
      <!-- 横向走廊分隔线 y=545/772 -->
      <view class="wall-h hall-divider"></view>
      <!-- 纵向分隔 x=370, x=598 -->
      <view class="wall-v wall-v1"></view>
      <view class="wall-v wall-v2"></view>
      <view class="wall-v wall-v3"></view>

      <!-- 分区标签 -->
      <text class="zone-label z-imm-left">沉浸区</text>
      <text class="zone-label z-imm-mid">沉浸区</text>
      <text class="zone-label z-imm-low">沉浸区</text>
      <text class="zone-label z-wc">卫生间</text>
      <text class="zone-label z-std">标准区</text>

      <!-- 休息区虚线框 -->
      <view class="rest-dash rest-imm-low"><text>休息区</text></view>

      <!-- 门洞 -->
      <view class="door door-imm-left"></view>
      <view class="door door-imm-mid"></view>
      <view class="door door-imm-low"></view>
      <view class="door door-std"></view>

      <!-- 标准区浅绿底 -->
      <view class="fill-standard"></view>

      <!-- 座位 -->
      <view class="seats-layer">
        <view
          wx:for="{{markers}}"
          wx:for-item="seat"
          wx:key="map_slot"
          class="seat-anchor"
          style="left: {{seat.left}}%; top: {{seat.top}}%;"
        >
          <template is="seatUnit" data="{{seat: seat, selectedId: selectedId}}" />
        </view>
      </view>
    </view>

    <view class="plan-footer">
      <view class="fac fac-rest"><text>休息区</text></view>
      <view class="fac fac-wc"><text>卫生间</text></view>
      <view class="fac-split">
        <view class="fac fac-tea"><text>茶水间</text></view>
        <view class="fac fac-dine"><text>餐厅</text></view>
      </view>
      <view class="fac fac-entry">
        <text>入口</text>
        <view class="entry-doors"></view>
      </view>
    </view>
  </view>
</view>
