<view class="plan-canvas">
  <movable-area class="plan-area" scale-area>
    <movable-view
      class="plan-move"
      direction="all"
      scale
      scale-min="1"
      scale-max="4"
      scale-value="{{scaleValue}}"
      inertia
      bindscale="onScale"
    >
      <view class="floor">
        <!-- 区域底色 -->
        <view class="room room--a"></view>
        <view class="room room--b"></view>
        <view class="room room--c"></view>
        <view class="room room--d"></view>

        <!-- 服务区（实线围合） -->
        <view class="svc svc--wc"></view>
        <view class="svc svc--strip"></view>
        <view class="strip-split"></view>

        <!-- 休息区（虚线围合） -->
        <view class="rest"></view>

        <!-- 1、2 号座位间 -->
        <view class="niche"></view>

        <!-- 外墙 -->
        <view class="wall wall--top"></view>
        <view class="wall wall--left"></view>
        <view class="wall wall--right"></view>
        <view class="wall wall--bottom-l"></view>
        <view class="wall wall--bottom-r"></view>
        <view class="wall wall--notch-jamb"></view>

        <!-- 竖向隔墙（走廊处断开） -->
        <view class="wall wall--v1-top"></view>
        <view class="wall wall--v1-bot"></view>
        <view class="wall wall--v2-top"></view>
        <view class="wall wall--v2-bot"></view>

        <!-- 走廊上下横墙（留门洞） -->
        <view class="wall wall--ct1"></view>
        <view class="wall wall--ct2"></view>
        <view class="wall wall--ct3"></view>
        <view class="wall wall--cb1"></view>
        <view class="wall wall--cb2"></view>
        <view class="wall wall--cb3"></view>

        <!-- 窗户 -->
        <view class="win win--h win--a"></view>
        <view class="win win--h win--b"></view>
        <view class="win win--h win--c"></view>
        <view class="win win--h win--bl"></view>

        <!-- 门（门扇 + 开启弧线） -->
        <view class="door door--down door--a"><view class="door-leaf"></view></view>
        <view class="door door--down door--b"><view class="door-leaf"></view></view>
        <view class="door door--down door--d"><view class="door-leaf"></view></view>
        <view class="door door--down door--wc"><view class="door-leaf"></view></view>
        <view class="door door--up-r door--entry-l"><view class="door-leaf"></view></view>
        <view class="door door--up-l door--entry-r"><view class="door-leaf"></view></view>

        <!-- 分区文字 -->
        <text class="lbl lbl--zone lbl--za">沉浸区</text>
        <text class="lbl lbl--zone lbl--zb">沉浸区</text>
        <text class="lbl lbl--zone lbl--zc">标准区</text>
        <text class="lbl lbl--zone lbl--zd">沉浸区</text>
        <text class="lbl lbl--svc lbl--wc">卫生间</text>
        <text class="lbl lbl--svc lbl--rest">休息区</text>
        <text class="lbl lbl--svc lbl--tea">茶水间</text>
        <text class="lbl lbl--svc lbl--dine">餐厅</text>
        <text class="lbl lbl--entry">入口</text>

        <!-- 座位层（可点击，交互逻辑保持不变） -->
        <view class="seats-layer">
          <view
            wx:for="{{markers}}"
            wx:for-item="seat"
            wx:key="map_slot"
            class="seat-anchor orient-{{seat.orient}}"
            style="left: {{seat.left}}%; top: {{seat.top}}%;"
            catchtap="onTap"
            data-id="{{seat.id}}"
            data-code="{{seat.seat_code}}"
            data-status="{{seat.status}}"
          >
            <view wx:if="{{seat.status !== 'empty'}}" class="seat-unit">
              <view class="desk-bar"></view>
              <view class="seat-chip {{seat.status}} {{selectedId===seat.id?'is-selected':''}}">
                <text wx:if="{{seat.map_label}}" class="seat-chip-label {{selectedId===seat.id ? 'seat-chip-label--active' : ''}}">{{seat.map_label}}</text>
              </view>
              <view class="desk-bar"></view>
            </view>
          </view>
        </view>
      </view>
    </movable-view>
  </movable-area>
</view>
