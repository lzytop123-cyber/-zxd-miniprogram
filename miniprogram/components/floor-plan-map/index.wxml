<template name="seatUnit">
  <view class="seat-cell {{seat.status}} {{selectedId===seat.id?'is-selected':''}}">
    <text wx:if="{{selectedId===seat.id}}" class="seat-cell-num">{{seat.map_label}}</text>
  </view>
</template>

<view class="plan-canvas">
  <!-- 原始平面图：1:1 铺满，保证 99% 还原 -->
  <image class="plan-img" src="/assets/floor-plan-default.png" mode="scaleToFill" />

  <!-- 可点选座位叠加层 -->
  <view class="seats-layer">
    <view
      wx:for="{{markers}}"
      wx:for-item="seat"
      wx:key="map_slot"
      class="seat-anchor"
      style="left: {{seat.left}}%; top: {{seat.top}}%;"
      bindtap="onTap"
      data-id="{{seat.id}}"
      data-code="{{seat.seat_code}}"
      data-status="{{seat.status}}"
    >
      <template is="seatUnit" data="{{seat: seat, selectedId: selectedId}}" />
    </view>
  </view>
</view>
