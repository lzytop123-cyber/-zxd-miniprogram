<view class="plan-canvas">
  <movable-area class="plan-area" scale-area>
    <movable-view
      class="plan-move"
      direction="all"
      scale
      scale-min="1"
      scale-max="4"
      scale-value="{{scaleValue}}"
      inertia
      bindscale="onScale"
    >
      <view class="floor-plate">
        <view class="floor-border"></view>

        <view class="wall wall--top"></view>
        <view class="wall wall--left"></view>
        <view class="wall wall--right"></view>
        <view class="wall wall--bottom"></view>

        <view class="zone zone--immersive zone--left-top"></view>
        <view class="zone zone--immersive zone--left-bottom"></view>
        <view class="zone zone--work zone--center-top"></view>
        <view class="zone zone--standard zone--right"></view>
        <view class="zone zone--service zone--middle-bottom"></view>
        <view class="zone zone--service zone--bottom-left"></view>
        <view class="zone zone--service zone--bottom-right"></view>
        <view class="zone zone--service zone--rest-center"></view>

        <text class="zone-label zone-label--left-top">沉浸区</text>
        <text class="zone-label zone-label--left-bottom">沉浸区</text>
        <text class="zone-label zone-label--center-top">工位区</text>
        <text class="zone-label zone-label--right">标准区</text>
        <text class="zone-label zone-label--service">休息 / 茶水</text>

        <view class="divider divider--vertical-left"></view>
        <view class="divider divider--vertical-middle"></view>
        <view class="divider divider--horizontal-upper"></view>
        <view class="divider divider--horizontal-middle"></view>
        <view class="divider divider--entry-notched"></view>

        <view class="arch arch--left"></view>
        <view class="arch arch--middle"></view>
        <view class="arch arch--entry"></view>

        <text class="small-label small-label--entry">入口</text>
        <text class="small-label small-label--service">茶水间</text>

        <view class="seats-layer">
          <view
            wx:for="{{markers}}"
            wx:for-item="seat"
            wx:key="map_slot"
            class="seat-anchor"
            style="left: {{seat.left}}%; top: {{seat.top}}%;"
            catchtap="onTap"
            data-id="{{seat.id}}"
            data-code="{{seat.seat_code}}"
            data-status="{{seat.status}}"
          >
            <view class="seat-chip {{seat.status}} {{selectedId===seat.id?'is-selected':''}} {{seat.status==='empty'?'is-hidden':''}}">
              <text wx:if="{{seat.map_label && seat.status !== 'empty'}}" class="seat-chip-label {{selectedId===seat.id ? 'seat-chip-label--active' : ''}}">{{seat.map_label}}</text>
            </view>
          </view>
        </view>
      </view>
    </movable-view>
  </movable-area>
</view>
