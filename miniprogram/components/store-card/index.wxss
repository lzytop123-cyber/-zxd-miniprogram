.store-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(28, 43, 32, 0.06);
}

.store-card:active {
  opacity: 0.92;
  transform: scale(0.995);
}

.cover-wrap {
  position: relative;
  height: 280rpx;
  background: #EEF7F1;
}

.cover {
  width: 100%;
  height: 280rpx;
  display: block;
}

.cover-placeholder {
  position: relative;
  overflow: hidden;
}

.placeholder-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #D8F3DC 0%, #95D5B2 50%, #52B788 100%);
  opacity: 0.35;
}

.placeholder-content {
  position: relative;
  z-index: 1;
  height: 280rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.placeholder-icon {
  font-size: 56rpx;
}

.cover-logo {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D6A4F;
  letter-spacing: 2rpx;
}

.status-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 600;
  backdrop-filter: blur(8rpx);
}

.status-tag.open {
  background: rgba(216, 243, 220, 0.95);
  color: #2D6A4F;
}

.status-tag.closed {
  background: rgba(236, 239, 241, 0.95);
  color: #8C9BA5;
}

.info {
  padding: 28rpx 24rpx;
}

.name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C2B20;
  flex: 1;
}

.arrow {
  font-size: 36rpx;
  color: #CFD8DC;
  line-height: 1;
}

.addr-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-top: 12rpx;
  gap: 16rpx;
}

.addr {
  flex: 1;
  font-size: 24rpx;
  color: #8C9BA5;
  line-height: 1.5;
}

.dist {
  font-size: 24rpx;
  color: #52B788;
  font-weight: 600;
  white-space: nowrap;
  padding: 4rpx 12rpx;
  background: #F4FAF6;
  border-radius: 8rpx;
}
