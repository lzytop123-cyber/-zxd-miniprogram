<view class="store-card" bindtap="onTap">
  <view class="cover-wrap">
    <image
      wx:if="{{store.cover_images && store.cover_images.length && store.cover_images[0] && !coverFailed}}"
      class="cover"
      src="{{store.cover_images[0]}}"
      mode="aspectFill"
      lazy-load
      binderror="onCoverError"
    />
    <view wx:else class="cover cover-placeholder">
      <view class="placeholder-bg"></view>
      <view class="placeholder-content">
        <view class="placeholder-icon">📚</view>
        <text class="cover-logo">知行岛自习室</text>
      </view>
    </view>
    <view class="status-tag {{store.status === 1 ? 'open' : 'closed'}}">
      {{store.status === 1 ? '营业中' : '已打烊'}}
    </view>
  </view>
  <view class="info">
    <view class="name-row">
      <text class="name">{{store.name}}</text>
      <text class="arrow">›</text>
    </view>
    <view class="addr-row" catchtap="onNavigate">
      <view class="addr-block">
        <text class="addr">{{store.address}}</text>
        <text class="nav-link" wx:if="{{canNavigate}}">地图导航 ›</text>
      </view>
      <text class="dist" wx:if="{{store.distance != null}}">{{store.distanceLabel || store.distance + 'km'}}</text>
      <text class="dist dist-hint" wx:elif="{{showLocationHint}}">开启定位查看距离</text>
    </view>
  </view>
</view>
