.booking-flow {
  margin: 24rpx 24rpx 0;
  border-radius: 32rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(28, 43, 32, 0.06);
}

.booking-flow--hero {
  width: 100%;
  height: 100%;
  margin: 0;
  border-radius: 0;
  box-shadow: none;
  background: transparent;
}

.flow-image {
  display: block;
  width: 100%;
}

.flow-image--hero {
  width: 100%;
  height: 100%;
}

.flow-canvas {
  display: block;
  width: 100%;
}

.flow-canvas--hero {
  width: 100%;
  height: 100%;
}

.flow-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F4FAF6;
}

.flow-placeholder--hero {
  background: linear-gradient(160deg, #2D6A4F 0%, #40916C 46%, #52B788 100%);
}

.flow-placeholder-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.booking-flow:not(.booking-flow--hero) .flow-placeholder-text {
  color: #8C9BA5;
}
