<view class="booking-flow {{mode === 'hero' ? 'booking-flow--hero' : ''}}">
  <image
    wx:if="{{imagePath}}"
    class="flow-image {{mode === 'hero' ? 'flow-image--hero' : ''}}"
    src="{{imagePath}}"
    mode="{{mode === 'hero' ? 'aspectFill' : 'widthFix'}}"
    show-menu-by-longpress="{{false}}"
  />
  <canvas
    wx:elif="{{ready}}"
    type="2d"
    id="flowCanvas"
    class="flow-canvas {{mode === 'hero' ? 'flow-canvas--hero' : ''}}"
    style="width: 100%; height: {{canvasHeight}}px;"
  />
  <view
    wx:else
    class="flow-placeholder {{mode === 'hero' ? 'flow-placeholder--hero' : ''}}"
    style="height: {{placeholderHeight}}px;"
  >
    <text class="flow-placeholder-text">{{mode === 'hero' ? '加载指引…' : '加载流程图…'}}</text>
  </view>
</view>
