.packages-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.page-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(28, 43, 32, 0.05);
}

.store-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 32rpx 8rpx;
}

.store-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #1C2B20;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-switch {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #52B788;
  font-weight: 600;
}

.tab-scroll {
  width: 100%;
  white-space: nowrap;
}

.tab-row {
  display: inline-flex;
  padding: 8rpx 24rpx 20rpx;
  gap: 32rpx;
}

.tab-item {
  position: relative;
  padding: 8rpx 4rpx 16rpx;
  font-size: 28rpx;
  color: #8C9BA5;
}

.tab-item.active {
  color: #2D6A4F;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #52B788;
}

/* ============ 我的期限卡紧凑条 ============ */
.my-strip {
  margin: 16rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: var(--shadow-card);
}

.my-strip-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.my-strip-title {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.my-strip-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.my-strip-count {
  font-size: 22rpx;
  color: #52B788;
  font-weight: 600;
}

.my-strip-more,
.my-strip-link {
  font-size: 24rpx;
  color: #52B788;
  font-weight: 600;
}

.my-strip--empty,
.my-strip--guest {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #8C9BA5;
}

.my-scroll {
  width: 100%;
  white-space: nowrap;
}

.my-scroll-inner {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.my-chip {
  display: inline-block;
  width: 280rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #D8F3DC 100%);
  vertical-align: top;
  white-space: normal;
}

.my-chip-type {
  display: inline-block;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(45, 106, 79, 0.12);
  color: #2D6A4F;
}

.my-chip-name {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #1C2B20;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.my-chip-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8C9BA5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============ 购买区域 ============ */
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 28rpx 32rpx 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2D6A4F;
}

.section-sub {
  font-size: 24rpx;
  color: #8C9BA5;
}

.buy-body {
  padding: 8rpx 24rpx 24rpx;
}

.loading {
  padding: 80rpx;
  text-align: center;
  color: #8C9BA5;
}

.pkg-list {
  padding-top: 8rpx;
}

.pkg-ticket {
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2D6A4F 0%, #40916C 55%, #52B788 100%);
  color: #fff;
  box-shadow: 0 16rpx 40rpx rgba(45, 106, 79, 0.22);
}

.pkg-deco {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 10rpx,
    rgba(255, 255, 255, 0.05) 10rpx,
    rgba(255, 255, 255, 0.05) 20rpx
  );
  pointer-events: none;
}

.pkg-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding-right: 40rpx;
}

.pkg-name {
  flex: 1;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.3;
}

.pkg-price {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 600;
}

.pkg-price-num {
  font-size: 44rpx;
  font-weight: 800;
}

.pkg-tags {
  margin-top: 16rpx;
}

.pkg-tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.pkg-rule {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.55;
  opacity: 0.9;
  padding-right: 60rpx;
}

.pkg-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed rgba(255, 255, 255, 0.22);
}

.pkg-detail {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  font-size: 24rpx;
}

.pkg-buy {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #2D6A4F;
  font-size: 26rpx;
  font-weight: 700;
}

.buy-empty {
  margin-top: 16rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  background: #fff;
  border-radius: 32rpx;
  color: #8C9BA5;
  font-size: 28rpx;
  box-shadow: var(--shadow-card);
}

.buy-empty .empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

/* ============ 我的卡列表弹层 ============ */
.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 90;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.sheet-panel {
  width: 100%;
  max-height: 78vh;
  background: #F4FAF6;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  margin: 16rpx auto 0;
  border-radius: 999rpx;
  background: #D0D0D0;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2D6A4F;
}

.sheet-close {
  font-size: 28rpx;
  color: #8C9BA5;
}

.sheet-scroll {
  flex: 1;
  max-height: 56vh;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.sheet-foot {
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #52B788;
  background: #fff;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.ticket-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 20rpx;
  padding: 28rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2D6A4F 0%, #40916C 58%, #52B788 100%);
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(45, 106, 79, 0.2);
}

.ticket-card--sheet:last-child {
  margin-bottom: 24rpx;
}

.ticket-deco {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 120rpx;
  background: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 10rpx,
    rgba(255, 255, 255, 0.05) 10rpx,
    rgba(255, 255, 255, 0.05) 20rpx
  );
  pointer-events: none;
}

.ticket-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ticket-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
}

.ticket-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #2D6A4F;
  font-weight: 600;
}

.ticket-name {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  padding-right: 60rpx;
}

.ticket-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.88;
  line-height: 1.5;
}

.ticket-meta.highlight {
  font-size: 26rpx;
  font-weight: 600;
  opacity: 1;
}

.ticket-remain.urgent {
  color: #ffe082;
  font-weight: 600;
}

.ticket-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed rgba(255, 255, 255, 0.22);
}

.ticket-brief {
  flex: 1;
  font-size: 22rpx;
  opacity: 0.82;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ticket-more {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
}

/* ============ 详情弹层 ============ */
.detail-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.detail-sheet {
  width: 100%;
  max-height: 75vh;
  padding: 16rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-sizing: border-box;
}

.detail-handle {
  width: 64rpx;
  height: 8rpx;
  margin: 8rpx auto 24rpx;
  border-radius: 999rpx;
  background: #E0E0E0;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1C2B20;
  line-height: 1.35;
}

.detail-subtitle {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #52B788;
}

.detail-lines {
  margin-top: 28rpx;
  max-height: 40vh;
  overflow-y: auto;
}

.detail-line {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #4A5A50;
  line-height: 1.55;
}

.detail-dot {
  color: #52B788;
  font-weight: 700;
}

.detail-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-btn {
  text-align: center;
  padding: 24rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #E8F5E9;
  color: #2D6A4F;
}

.detail-btn.primary {
  background: #52B788;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(82, 183, 136, 0.35);
}
