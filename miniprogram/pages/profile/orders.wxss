.orders-page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.order-card {
  margin-bottom: 24rpx;
}

.order-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-store {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #2D6A4F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.status-active {
  background: #D8F3DC;
  color: #2D6A4F;
}

.status-booked {
  background: #E3F2FD;
  color: #1565C0;
}

.status-warn {
  background: #FFF8E6;
  color: #8A6D3B;
}

.status-done {
  background: #F4FAF6;
  color: #8C9BA5;
}

.status-muted {
  background: #ECEFF1;
  color: #8C9BA5;
}

.order-seat {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #4A5A50;
}

.order-time {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8C9BA5;
}

.order-hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #52B788;
  line-height: 1.5;
}

.order-action {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F4FAF6;
}

.action-btn {
  display: inline-block;
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  background: #52B788;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.orders-tip {
  font-size: 24rpx;
  color: #8C9BA5;
  line-height: 1.6;
  text-align: center;
}
