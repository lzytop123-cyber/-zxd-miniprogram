.label { font-weight: bold; margin-bottom: 10px; }
.code-row { display: flex; align-items: center; justify-content: space-between; }
.code { font-size: 20px; font-weight: bold; color: #FFD000; }
.copy-btn { padding: 6px 12px; border: 1px solid #FFD000; border-radius: 6px; font-size: 12px; }
.hint { font-size: 12px; color: #999; margin-top: 12px; line-height: 1.6; }
.input { border: 1px solid #eee; border-radius: 8px; padding: 12px; margin-bottom: 16px; }
