<view class="card">
  <view class="balance">当前余额：¥{{balance}}</view>
  <view class="amounts">
    <view class="amt {{amount==50?'active':''}}" bindtap="setAmount" data-a="50">50元</view>
    <view class="amt {{amount==100?'active':''}}" bindtap="setAmount" data-a="100">100元</view>
    <view class="amt {{amount==200?'active':''}}" bindtap="setAmount" data-a="200">200元</view>
    <view class="amt {{amount==500?'active':''}}" bindtap="setAmount" data-a="500">500元</view>
  </view>
  <view class="btn-primary" bindtap="recharge">立即充值</view>
</view>

<view class="card">
  <view class="title">充值记录</view>
  <view class="log" wx:for="{{logs}}" wx:key="id">
    <view>{{item.remark}}</view>
    <view class="log-amt">+¥{{item.amount}}</view>
  </view>
</view>
