<view class="card profile-card" wx:if="{{user}}">
  <image class="avatar" src="{{user.avatar_url || 'https://via.placeholder.com/80'}}" />
  <view class="nickname">{{user.nickname}}</view>
  <view class="title-badge">{{user.title || '小白'}}</view>
  <view class="stats">
    <view>余额 ¥{{user.balance}}</view>
    <view>积分 {{user.total_points}}</view>
  </view>
</view>

<view class="card menu">
  <view class="menu-item" bindtap="go" data-url="/pages/profile/wallet">余额充值 ›</view>
  <view class="menu-item" bindtap="go" data-url="/pages/profile/orders">预定订单 ›</view>
  <view class="menu-item" bindtap="go" data-url="/pages/profile/cards">期限卡 ›</view>
  <view class="menu-item" bindtap="go" data-url="/pages/profile/coupons">优惠券 ›</view>
  <view class="menu-item" bindtap="go" data-url="/pages/profile/points">我的积分 ›</view>
  <view class="menu-item" bindtap="go" data-url="/pages/profile/invite">邀请有礼 ›</view>
  <view class="menu-item" bindtap="go" data-url="/pages/profile/face">人脸录入 ›</view>
  <button class="menu-item phone-btn" open-type="getPhoneNumber" bindgetphonenumber="bindPhone">绑定手机号 ›</button>
</view>
