<view class="page-profile page-safe-bottom">
  <view class="profile-header {{loginState === 'guest' ? 'guest' : ''}}">
    <block wx:if="{{loginState === 'guest'}}">
      <view class="guest-header" bindtap="goLogin">
        <view class="avatar avatar-placeholder guest">?</view>
        <view class="nickname">未登录</view>
        <view class="guest-login-tip">点击登录</view>
      </view>
    </block>

    <block wx:elif="{{loginState === 'loading'}}">
      <view class="avatar avatar-placeholder">岛</view>
      <view class="nickname">加载中...</view>
    </block>

    <block wx:elif="{{loginState === 'ready' && user}}">
      <button class="avatar-picker inline" hover-class="none" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image
          wx:if="{{avatarDisplay}}"
          class="avatar"
          src="{{avatarDisplay}}"
          mode="aspectFill"
        />
        <view wx:else class="avatar avatar-placeholder">岛</view>
      </button>
      <view class="nickname">{{user.nickname}}</view>
      <view class="title-badge">{{user.title || '小白'}}</view>

      <view class="id-row" bindtap="copyUserId">
        <text class="id-label">学号</text>
        <text class="id-val">#{{user.id}}</text>
        <text class="id-copy">复制</text>
      </view>

      <view class="phone-line" wx:if="{{user.phone}}">手机 {{user.phone}}</view>
      <view class="phone-line muted" wx:else>未绑定手机</view>

      <view class="stats-row">
        <view class="stat-pill">
          <view class="stat-val">¥{{user.balance}}</view>
          <view class="stat-key">余额</view>
        </view>
        <view class="stat-pill">
          <view class="stat-val">{{user.total_points}}</view>
          <view class="stat-key">积分</view>
        </view>
      </view>

      <view class="edit-row" wx:if="{{avatarUploading}}">
        <view class="btn-outline small">头像更新中...</view>
      </view>
    </block>
  </view>

  <view class="goal-card card" wx:if="{{loginState === 'ready' && user}}">
    <view class="goal-card-title">备考方向</view>
    <view class="goal-chips">
      <view
        wx:for="{{goalOptions}}"
        wx:key="value"
        class="goal-chip {{user.study_goal === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="saveStudyGoal"
      >{{item.label}}</view>
    </view>
  </view>

  <view class="menu-grid card">
    <view class="menu-item" bindtap="go" data-url="{{menuUrls.wallet}}">
      <view class="menu-icon">💰</view>
      <text>钱包</text>
    </view>
    <view class="menu-item" bindtap="go" data-url="{{menuUrls.orders}}">
      <view class="menu-icon">📋</view>
      <text>我的订单</text>
    </view>
        <view class="menu-item" bindtap="goPackages">
          <view class="menu-icon">🎫</view>
          <text>我的期限卡</text>
        </view>
    <view class="menu-item" bindtap="go" data-url="{{menuUrls.coupons}}">
      <view class="menu-icon">🏷</view>
      <text>优惠券</text>
    </view>
    <view class="menu-item" bindtap="go" data-url="{{menuUrls.points}}">
      <view class="menu-icon">⭐</view>
      <text>积分明细</text>
    </view>
    <view class="menu-item" bindtap="go" data-url="{{menuUrls.invite}}">
      <view class="menu-icon">🎁</view>
      <text>邀请有礼</text>
    </view>
    <!-- <view class="menu-item" bindtap="go" data-url="/pages/profile/face">
      <view class="menu-icon">👤</view>
      <text>人脸录入</text>
    </view> -->
    <button class="menu-item phone-btn" open-type="contact">
      <view class="menu-icon">💬</view>
      <text>联系店长</text>
    </button>
    <button
      wx:if="{{loginState === 'ready' && user}}"
      class="menu-item phone-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="bindPhone"
    >
      <view class="menu-icon">📱</view>
      <text>{{user.phone ? '更换手机' : '绑定手机'}}</text>
    </button>
    <view wx:else class="menu-item" bindtap="goLogin">
      <view class="menu-icon">📱</view>
      <text>绑定手机</text>
    </view>
  </view>

  <view class="logout-row" wx:if="{{loginState === 'ready' && user}}">
    <view class="btn-logout" bindtap="doLogout">退出登录</view>
  </view>
</view>
