.balance { font-size: 24px; font-weight: bold; text-align: center; margin-bottom: 20px; }
.amounts { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
.amt { flex: 1; min-width: 40%; text-align: center; padding: 12px; border: 1px solid #eee; border-radius: 8px; }
.amt.active { border-color: #FFD000; background: #fff9e0; }
.title { font-weight: bold; margin-bottom: 12px; }
.log { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #f0f0f0; font-size: 12px; }
.log-amt { color: #4CAF50; }
