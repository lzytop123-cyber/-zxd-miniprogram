.page-profile {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.login-loading {
  padding: 120rpx 32rpx;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #8C9BA5;
}

.login-error {
  margin: 32rpx 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
}

.login-error-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C2B20;
}

.login-error-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #E07A5F;
}

.login-retry {
  margin-top: 32rpx;
}

.login-hint {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #8C9BA5;
  line-height: 1.6;
}

.setup-card {
  margin: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
}

.setup-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1C2B20;
}

.setup-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8C9BA5;
  line-height: 1.5;
}

.avatar-picker {
  margin: 32rpx auto 0;
  padding: 0;
  background: transparent;
  line-height: normal;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-picker::after {
  border: none;
}

.avatar-picker.inline {
  margin-top: 0;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  background: #D8F3DC;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #2D6A4F;
  border-color: #52B788;
}

.setup-card .avatar {
  border-color: #52B788;
}

.avatar-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #52B788;
}

.nickname-field {
  margin-top: 32rpx;
  text-align: left;
}

.field-label {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-bottom: 12rpx;
}

.nickname-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #F4FAF6;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1C2B20;
}

.setup-save {
  margin-top: 32rpx;
}

.setup-note {
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #8C9BA5;
}

.profile-header {
  background: linear-gradient(160deg, #2D6A4F 0%, #52B788 100%);
  padding: 48rpx 32rpx 64rpx;
  border-radius: 0 0 48rpx 48rpx;
  text-align: center;
  color: #FFFFFF;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 20rpx;
}

.title-badge {
  display: inline-block;
  margin-top: 12rpx;
  padding: 6rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 24rpx;
}

.phone-line {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.phone-line.muted {
  opacity: 0.75;
}

.stats-row {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 32rpx;
}

.stat-pill {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 20rpx 40rpx;
  min-width: 160rpx;
}

.stat-val {
  font-size: 32rpx;
  font-weight: 700;
}

.stat-key {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

.edit-row {
  margin-top: 20rpx;
}

.btn-outline.small {
  display: inline-block;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  border-radius: 40rpx;
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
}

.menu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  padding: 8rpx 0;
  margin: 24rpx;
  position: relative;
  z-index: 2;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  font-size: 26rpx;
  color: #1C2B20;
  border-bottom: 2rpx solid #F4FAF6;
}

.menu-item:nth-child(odd) {
  border-right: 2rpx solid #F4FAF6;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #D8F3DC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.phone-btn {
  background: transparent;
  line-height: normal;
  font-weight: normal;
}

.phone-btn::after {
  border: none;
}
