<view class="page-exchange page-safe-bottom">
  <view class="card exchange-card">
    <view class="platform-tabs">
      <view
        class="platform-tab {{platform === 'meituan' ? 'active' : ''}}"
        data-platform="meituan"
        bindtap="onPlatformTap"
      >美团</view>
      <view
        class="platform-tab {{platform === 'douyin' ? 'active' : ''}}"
        data-platform="douyin"
        bindtap="onPlatformTap"
      >抖音</view>
    </view>
    <view class="exchange-header">
      <view class="exchange-icon">🎟</view>
      <view class="exchange-title">{{platformLabel}}团购兑换</view>
    </view>

    <block wx:if="{{platform === 'douyin'}}">
      <view class="hint">对准抖音购买页二维码扫码，无需手输数字</view>
      <view class="scan-ready {{scanReady ? 'visible' : ''}}" wx:if="{{scanReady}}">✓ 已识别抖音券，点击立即兑换</view>
      <view class="code-field">
        <input
          class="code-input {{scanReady ? 'code-input--scan' : ''}}"
          placeholder="扫码后自动识别；也可手动输入12位券号"
          value="{{code}}"
          bindinput="onInput"
          maxlength="256"
          confirm-type="done"
          bindconfirm="onSubmitTap"
        />
        <view class="code-scan {{loading || scanning ? 'disabled' : ''}}" bindtap="onScanTap">
          <text class="code-scan-icon">📷</text>
        </view>
      </view>
      <view class="album-link {{loading || scanning ? 'disabled' : ''}}" bindtap="onAlbumScanTap">从相册识别二维码</view>
    </block>

    <block wx:else>
      <view class="hint">扫码或相册识别券码</view>
      <view class="code-field">
        <input
          class="code-input"
          placeholder="请输入券码"
          value="{{code}}"
          bindinput="onInput"
          maxlength="32"
          confirm-type="done"
          bindconfirm="onSubmitTap"
        />
        <view class="code-scan {{loading || scanning ? 'disabled' : ''}}" bindtap="onScanTap">
          <text class="code-scan-icon">📷</text>
        </view>
      </view>
      <view class="album-link {{loading || scanning ? 'disabled' : ''}}" bindtap="onAlbumScanTap">从相册识别券码</view>
    </block>

    <view class="btn-primary {{loading?'disabled':''}}" bindtap="onSubmitTap">立即兑换</view>
    <view class="link-records" bindtap="goRecords">查看兑换记录 ›</view>
  </view>
</view>
