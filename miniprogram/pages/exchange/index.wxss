.page-exchange {
  min-height: 100vh;
}

.exchange-card {
  margin-top: 32rpx;
}

.exchange-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.exchange-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #D8F3DC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.exchange-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.code-input {
  border: 2rpx solid #D8F3DC;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 24rpx 0 32rpx;
  background: #F4FAF6;
  font-size: 30rpx;
}

.link-records {
  text-align: center;
  color: #52B788;
  font-size: 26rpx;
  margin-top: 24rpx;
  font-weight: 600;
}
