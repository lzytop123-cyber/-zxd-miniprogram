.page-exchange {
  min-height: 100vh;
}

.exchange-card {
  margin-top: 32rpx;
}

.platform-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
  padding: 8rpx;
  border-radius: 20rpx;
  background: #F4FAF6;
}

.platform-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #52B788;
}

.platform-tab.active {
  background: #fff;
  color: #2D6A4F;
  box-shadow: 0 4rpx 16rpx rgba(45, 106, 79, 0.08);
}

.exchange-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.exchange-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #D8F3DC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.exchange-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.code-field {
  display: flex;
  align-items: stretch;
  border: 2rpx solid #D8F3DC;
  border-radius: 16rpx;
  margin: 28rpx 0 32rpx;
  background: #F4FAF6;
  overflow: hidden;
}

.code-input {
  flex: 1;
  min-width: 0;
  padding: 24rpx 12rpx 24rpx 24rpx;
  font-size: 30rpx;
  background: transparent;
}

.code-scan {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  flex-shrink: 0;
  border-left: 2rpx solid #D8F3DC;
  background: rgba(255, 255, 255, 0.55);
}

.code-scan.disabled {
  opacity: 0.45;
}

.code-scan-icon {
  font-size: 40rpx;
  line-height: 1;
}

.code-input--scan {
  color: #2D6A4F;
  font-weight: 600;
}

.scan-ready {
  display: none;
  margin: -8rpx 0 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #E8F8EE;
  color: #2D6A4F;
  font-size: 26rpx;
  font-weight: 600;
}

.scan-ready.visible {
  display: block;
}

.album-link {
  margin: -8rpx 0 28rpx;
  text-align: center;
  font-size: 24rpx;
  color: #52B788;
  font-weight: 600;
}

.album-link.disabled {
  opacity: 0.45;
}

.link-records {
  text-align: center;
  color: #52B788;
  font-size: 26rpx;
  margin-top: 24rpx;
  font-weight: 600;
}
