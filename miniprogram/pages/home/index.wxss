.page-home {
  min-height: 100vh;
  padding-bottom: 24rpx;
}

/* ============ Hero ============ */
.hero {
  position: relative;
  overflow: hidden;
  border-radius: 0 0 52rpx 52rpx;
  background: linear-gradient(160deg, #2D6A4F 0%, #40916C 46%, #52B788 100%);
  box-shadow: 0 24rpx 48rpx rgba(45, 106, 79, 0.18);
}

.hero-decor {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.hero-media {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.hero-swiper,
.hero-swiper--single {
  width: 100%;
}

.hero-swiper--single {
  overflow: hidden;
}

.hero-fallback {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #2D6A4F 0%, #40916C 46%, #52B788 100%);
}

.hero-fallback .hero-grid {
  position: absolute;
  inset: 0;
  opacity: 0.15;
}

.hero-fallback-text {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 4rpx;
}

.hero-fallback--loading {
  animation: hero-pulse 1.2s ease-in-out infinite;
}

.hero-skeleton-lines {
  position: relative;
  z-index: 1;
  width: 60%;
  padding: 0 32rpx;
}

.hero-skeleton-line {
  height: 36rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.25);
}

.hero-skeleton-line--short {
  width: 50%;
  height: 28rpx;
}

.location-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin: 0 32rpx 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(82, 183, 136, 0.1);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--color-primary-dark);
}

.location-hint-action {
  margin-left: auto;
  color: var(--color-primary);
  font-weight: 600;
}

@keyframes hero-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.85; }
}

.hero-swiper-item {
  height: 100%;
  overflow: hidden;
}

.hero-slide {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.hero-slide-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-slide-bg--text {
  background: linear-gradient(160deg, #2D6A4F 0%, #40916C 46%, #52B788 100%);
}

.hero-slide-bg--card {
  top: 132rpx;
  bottom: 132rpx;
  left: 0;
  right: 0;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(15, 45, 30, 0.22);
}

.hero-slide-tap {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.hero-slide-content {
  position: absolute;
  z-index: 3;
  left: 0;
  right: 0;
  top: 132rpx;
  bottom: 148rpx;
  padding: 0 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
}

.hero-slide-content--card {
  top: 152rpx;
  bottom: 168rpx;
  justify-content: flex-end;
}

.hero-slide-content--overlay {
  background: linear-gradient(180deg, rgba(15, 45, 30, 0.05) 0%, rgba(15, 45, 30, 0.55) 100%);
  justify-content: flex-end;
  padding-bottom: 24rpx;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  z-index: 5;
  display: flex;
  flex-direction: column;
  padding: 28rpx 32rpx 36rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.hero-overlay::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(180deg, rgba(10, 30, 20, 0.48) 0%, rgba(10, 30, 20, 0.12) 55%, transparent 100%);
  pointer-events: none;
}

.hero-overlay::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 220rpx;
  background: linear-gradient(0deg, rgba(10, 30, 20, 0.42) 0%, rgba(10, 30, 20, 0.08) 60%, transparent 100%);
  pointer-events: none;
}

.hero-top {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  pointer-events: auto;
}

.hero-search {
  position: relative;
  z-index: 2;
  margin-top: auto;
  pointer-events: auto;
}

.hero--card .hero-slide-bg--card {
  left: 32rpx;
  right: 32rpx;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(2rpx);
  opacity: 0.35;
  pointer-events: none;
}

.orb-1 {
  width: 320rpx;
  height: 320rpx;
  right: -90rpx;
  top: -120rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0));
}

.orb-2 {
  width: 220rpx;
  height: 220rpx;
  left: -70rpx;
  bottom: 40rpx;
  background: radial-gradient(circle, rgba(255, 183, 3, 0.45), rgba(255, 183, 3, 0));
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(255, 255, 255, 0.06) 2rpx, transparent 2rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.06) 2rpx, transparent 2rpx);
  background-size: 56rpx 56rpx;
  pointer-events: none;
}

.brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-logo {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #2D6A4F;
  font-size: 40rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 26rpx rgba(20, 50, 35, 0.28);
}

.brand-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

.brand-slogan {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  margin-top: 6rpx;
}

.hero-points {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 22rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 22rpx;
  backdrop-filter: blur(6rpx);
}

.hero-points-val {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFE9A8;
  line-height: 1.1;
}

.hero-points-key {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 活动内容样式 */
.campaign-ribbon {
  display: inline-block;
  padding: 8rpx 22rpx;
  background: linear-gradient(135deg, #FFB703, #FB8500);
  color: #4A2A00;
  font-size: 22rpx;
  font-weight: 800;
  border-radius: 8rpx 20rpx 20rpx 8rpx;
  box-shadow: 0 6rpx 16rpx rgba(251, 133, 0, 0.4);
}

.campaign-title {
  margin-top: 20rpx;
}

.ct-line {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.18;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 18rpx rgba(15, 45, 30, 0.25);
}

.ct-line--sm {
  font-size: 40rpx;
  margin-top: 4rpx;
}

.campaign-foot {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.campaign-date {
  display: flex;
  flex-direction: column;
}

.cd-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.cd-range {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  margin-top: 2rpx;
}

.campaign-cta {
  padding: 18rpx 40rpx;
  background: #FFFFFF;
  color: #2D6A4F;
  font-size: 28rpx;
  font-weight: 800;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 45, 30, 0.25);
}

.campaign-cta:active {
  transform: scale(0.96);
}

/* 搜索 */
.search-bar {
  position: relative;
  z-index: 2;
  margin-top: 0;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 45, 30, 0.16);
  backdrop-filter: blur(12rpx);
}

.search-icon {
  color: #52B788;
  font-size: 32rpx;
  font-weight: 700;
}

.search-placeholder {
  font-size: 26rpx;
  color: #8C9BA5;
}

/* ============ 两大入口 ============ */
.entries {
  display: flex;
  gap: 24rpx;
  margin: -36rpx 24rpx 0;
  position: relative;
  z-index: 5;
}

.entry {
  position: relative;
  flex: 1;
  padding: 30rpx 26rpx 28rpx;
  border-radius: 30rpx;
  overflow: hidden;
  color: #FFFFFF;
  box-shadow: 0 14rpx 30rpx rgba(28, 43, 32, 0.16);
}

.entry:active {
  transform: translateY(2rpx);
}

.entry-book {
  background: linear-gradient(150deg, #2D6A4F, #52B788);
}

.entry-verify {
  background: linear-gradient(150deg, #F08C00, #FFB703);
}

.entry-deco {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  right: -60rpx;
  bottom: -70rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
}

.entry-en {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  opacity: 0.82;
  font-weight: 600;
}

.entry-cn {
  font-size: 38rpx;
  font-weight: 800;
  margin-top: 8rpx;
}

.entry-desc {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 10rpx;
}

.entry-icon {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  font-size: 44rpx;
  opacity: 0.95;
}

/* ============ 会员卡 ============ */
.member {
  margin: 28rpx 24rpx 0;
  padding: 28rpx;
  background: #FFFFFF;
  border-radius: 30rpx;
  box-shadow: var(--shadow-card);
}

.member-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.member-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.member-avatar-ph {
  background: linear-gradient(135deg, #52B788, #2D6A4F);
  color: #FFFFFF;
  font-size: 38rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-hi {
  font-size: 32rpx;
  font-weight: 800;
  color: #1C2B20;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
  min-width: 0;
}

.member-badge {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 12rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #2D6A4F;
  background: #D8F3DC;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.member-meta-dot {
  color: #C2CDD6;
  font-size: 22rpx;
  line-height: 1;
}

.member-summary-item {
  font-size: 22rpx;
  color: #6B7C71;
  line-height: 1.4;
}

.member-arrow {
  color: #C2CDD6;
  font-size: 40rpx;
  font-weight: 700;
}

.member-actions {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-top: 26rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #F0F4F1;
}

.member-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: 1.2;
  font-size: 22rpx;
  color: #3D5245;
}

.member-action-btn {
  border: none;
}

.member-action-btn::after {
  border: none;
}

.member-action-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #F3F8F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.member-stats {
  display: flex;
  align-items: center;
  margin-top: 26rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #F0F4F1;
}

.mstat {
  flex: 1;
  text-align: center;
}

.mstat-val {
  font-size: 32rpx;
  font-weight: 800;
  color: #2D6A4F;
}

.mstat-key {
  font-size: 22rpx;
  color: #8C9BA5;
  margin-top: 4rpx;
}

.mstat-line {
  width: 2rpx;
  height: 48rpx;
  background: #F0F4F1;
}

/* ============ 快捷功能 ============ */
/* ============ 邀请 Banner ============ */
.promo {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin: 4rpx 24rpx 8rpx;
  padding: 28rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(120deg, #FFF8E6 0%, #FDEFD0 100%);
  border: 2rpx solid #FCE3AE;
}

.promo:active {
  transform: scale(0.99);
}

.promo-spark {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(251, 133, 0, 0.18);
}

.promo-text {
  flex: 1;
  min-width: 0;
}

.promo-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #8A5A00;
}

.promo-sub {
  font-size: 22rpx;
  color: #B6862F;
  margin-top: 6rpx;
}

.promo-cta {
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #FB8500, #FFB703);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 800;
  border-radius: 36rpx;
  box-shadow: 0 6rpx 16rpx rgba(251, 133, 0, 0.32);
}

/* ============ 门店 ============ */
.section-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 20rpx 32rpx 4rpx;
}

.section-row .section-title {
  padding: 0;
}

.section-more {
  font-size: 24rpx;
  color: #8C9BA5;
}

.store-list {
  padding: 8rpx 24rpx 32rpx;
}

.announce-bar {
  margin: 20rpx 24rpx 0;
  padding: 20rpx 24rpx;
  background: #fff8e6;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 208, 0, 0.12);
}

.announce-icon {
  font-size: 28rpx;
}

.announce-text {
  flex: 1;
  font-size: 26rpx;
  color: #8a6d00;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.announce-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.announce-modal {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
}

.announce-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.announce-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #555;
  white-space: pre-wrap;
  max-height: 420rpx;
  overflow-y: auto;
}

.announce-btn {
  margin-top: 32rpx;
  background: #FFD000;
  color: #1a1a1a;
  border-radius: 999rpx;
  font-weight: 600;
}
