.page-home {
  min-height: 100vh;
  padding-bottom: 16rpx;
}

.home-header {
  padding: 16rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #52B788 0%, #52B788 55%, #F4FAF6 100%);
}

.brand {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.brand-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #2D6A4F;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(28, 43, 32, 0.12);
}

.brand-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.brand-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

.search-bar {
  margin: -8rpx 32rpx 0;
  padding: 22rpx 28rpx;
  background: #FFFFFF;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(28, 43, 32, 0.08);
  position: relative;
  z-index: 2;
}

.search-icon {
  color: #52B788;
  font-size: 32rpx;
  font-weight: 700;
}

.search-placeholder {
  font-size: 26rpx;
  color: #8C9BA5;
}

.banner-card {
  margin-top: 24rpx;
  padding: 0;
  overflow: hidden;
}

.banner-inner {
  padding: 44rpx 36rpx;
  background: linear-gradient(135deg, #2D6A4F 0%, #52B788 100%);
  border-radius: 32rpx;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  margin-top: 12rpx;
}

.shortcuts {
  display: flex;
  justify-content: space-between;
  text-align: center;
  padding: 32rpx 24rpx;
}

.shortcut {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #1C2B20;
}

.shortcut-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.shortcut-icon.meituan {
  background: #FFF4E5;
  color: #D48806;
}

.shortcut-icon.douyin {
  background: #F3E8FF;
  color: #7C3AED;
}

.shortcut-icon.period {
  background: #D8F3DC;
  color: #2D6A4F;
}

.shortcut-icon.coupon {
  background: #E8F4FD;
  color: #1976D2;
}

.store-list {
  padding: 0 24rpx 32rpx;
}

.section-title {
  padding-top: 8rpx;
}
