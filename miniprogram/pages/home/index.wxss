.banner-placeholder { height: 150px; background: linear-gradient(135deg, #FFD000, #ffe566); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: bold; color: #1a1a1a; }
.shortcuts { display: flex; justify-content: space-around; text-align: center; }
.shortcut { font-size: 12px; color: #1a1a1a; }
.section-title { padding: 12px 16px 0; font-weight: bold; }
.store-name { font-size: 16px; font-weight: bold; }
.store-addr { color: #888; margin-top: 4px; font-size: 12px; }
.store-dist { color: #FFD000; margin-top: 8px; font-size: 12px; }
