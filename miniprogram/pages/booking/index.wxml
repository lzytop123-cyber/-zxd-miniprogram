<view class="page-booking page-safe-bottom">
  <!-- 门店 Hero -->
  <view class="bk-hero">
    <view class="bk-hero-orb"></view>
    <view class="bk-hero-grid"></view>
    <view class="bk-hero-store">{{storeName}}</view>
  </view>

  <!-- 套餐类型 -->
  <view class="bk-card">
    <view class="bk-sec bk-sec--type">
      <view class="bk-bar"></view>
      <text>选择套餐</text>
      <text class="bk-sec-tag">{{selectedTypeLabel}}</text>
    </view>

    <view class="type-primary-grid">
      <view
        wx:for="{{primaryGroups}}"
        wx:key="key"
        class="type-primary {{activePrimaryKey===item.key?'active':''}}"
        bindtap="switchPrimary"
        data-key="{{item.key}}"
      >
        <text class="type-primary-label">{{item.label}}</text>
      </view>
      <view
        wx:if="{{showNightType}}"
        class="type-primary type-primary--night {{activePrimaryKey==='night'?'active':''}}"
        bindtap="switchType"
        data-type="night"
      >
        <text class="type-primary-label">夜读</text>
      </view>
    </view>

    <view class="type-sub-row" wx:if="{{showPeriodSubs}}">
      <view
        wx:for="{{periodOptions}}"
        wx:key="type"
        class="type-sub {{billType===item.type?'active':''}}"
        bindtap="switchType"
        data-type="{{item.type}}"
      >
        <text class="type-sub-label">{{item.label}}</text>
        <text class="type-sub-days">{{item.days}}</text>
      </view>
    </view>
  </view>

  <!-- 时间设置 -->
  <view class="bk-card">
    <view class="bk-sec"><view class="bk-bar"></view><text>使用时间</text></view>
    <view class="hint hint--sec" wx:if="{{billType !== 'night'}}">{{storeHoursHint}}</view>

    <!-- 按小时 -->
    <block wx:if="{{billType==='hourly'}}">
      <picker mode="date" value="{{startDate}}" start="{{today}}" bindchange="onStartDateChange">
        <view class="field"><text class="field-key">开始日期</text><text class="field-val">{{startDate}} ›</text></view>
      </picker>
      <picker mode="time" value="{{startClock}}" bindchange="onStartClockChange">
        <view class="field"><text class="field-key">开始时间</text><text class="field-val">{{startClock}} ›</text></view>
      </picker>
      <picker mode="time" value="{{endClock}}" bindchange="onEndClockChange">
        <view class="field"><text class="field-key">结束时间</text><text class="field-val">{{endClock}} ›</text></view>
      </picker>
      <view class="quick-btns">
        <view class="chip" bindtap="setHours" data-h="2">2小时</view>
        <view class="chip" bindtap="setHours" data-h="4">4小时</view>
        <view class="chip" bindtap="setHours" data-h="8">8小时</view>
      </view>
      <view class="hint">最少2小时，最长24小时</view>
    </block>

    <!-- 天卡 -->
    <block wx:if="{{billType==='daily'}}">
      <block wx:if="{{dailyUseMode==='multi_pass' && multiDayDailyCard}}">
        <view class="field"><text class="field-key">连续使用</text><text class="field-val">{{startDate}} 至 {{endDate}}</text></view>
        <view class="hint">须连续约满 {{multiDayDailyCard.daily_pass_days}} 天</view>
      </block>
      <block wx:else>
        <picker mode="date" value="{{startDate}}" start="{{today}}" bindchange="onStartDateChange">
          <view class="field"><text class="field-key">使用日期</text><text class="field-val">{{startDate}} ›</text></view>
        </picker>
        <picker mode="date" value="{{endDate}}" start="{{startDate}}" bindchange="onEndDateChange">
          <view class="field"><text class="field-key">结束日期</text><text class="field-val">{{endDate}} ›</text></view>
        </picker>
        <block wx:if="{{startDate === endDate}}">
          <picker mode="time" value="{{startClock}}" bindchange="onStartClockChange">
            <view class="field"><text class="field-key">开始时间</text><text class="field-val">{{startClock}} ›</text></view>
          </picker>
          <picker mode="time" value="{{endClock}}" bindchange="onEndClockChange">
            <view class="field"><text class="field-key">结束时间</text><text class="field-val">{{endClock}} ›</text></view>
          </picker>
          <view class="quick-btns">
            <view class="chip" bindtap="setDailyFullDay">全天</view>
            <view class="chip" bindtap="setDailyPreset" data-start="08:00" data-end="18:00">8-18点</view>
            <view class="chip" bindtap="setDailyPreset" data-start="09:00" data-end="21:00">9-21点</view>
          </view>
        </block>
        <view class="hint">单日可选时段，跨日全天</view>
      </block>
      <view class="quick-btns" wx:if="{{hasMultiDayDailyCard}}">
        <view class="chip {{dailyUseMode==='single'?'active':''}}" bindtap="setDailyMode" data-mode="single">单日预约</view>
        <view class="chip {{dailyUseMode==='multi_pass'?'active':''}}" bindtap="setDailyMode" data-mode="multi_pass">三天卡连续</view>
      </view>
    </block>

    <!-- 次卡 -->
    <block wx:if="{{billType==='session'}}">
      <picker mode="date" value="{{startDate}}" start="{{today}}" bindchange="onStartDateChange">
        <view class="field"><text class="field-key">开始日期</text><text class="field-val">{{startDate}} ›</text></view>
      </picker>
      <picker mode="date" value="{{endDate}}" start="{{startDate}}" bindchange="onEndDateChange">
        <view class="field"><text class="field-key">结束日期</text><text class="field-val">{{endDate}} ›</text></view>
      </picker>
      <view class="quick-btns">
        <view class="chip" bindtap="setSessionDays" data-d="1">1天</view>
        <view class="chip" bindtap="setSessionDays" data-d="3">3天</view>
        <view class="chip" bindtap="setSessionDays" data-d="7">7天</view>
      </view>
      <view class="hint">每自然日扣 1 次</view>
    </block>

    <!-- 周卡 / 月卡 / 季卡 -->
    <block wx:if="{{billType==='weekly' || billType==='monthly' || billType==='quarterly'}}">
      <picker mode="date" value="{{startDate}}" start="{{today}}" bindchange="onStartDateChange">
        <view class="field"><text class="field-key">开始日期</text><text class="field-val">{{startDate}} ›</text></view>
      </picker>
      <picker mode="date" value="{{endDate}}" start="{{startDate}}" bindchange="onEndDateChange">
        <view class="field"><text class="field-key">结束日期</text><text class="field-val">{{endDate}} ›</text></view>
      </picker>
    </block>

    <!-- 夜读 -->
    <block wx:if="{{billType==='night'}}">
      <picker mode="date" value="{{startDate}}" start="{{nightDateMin || today}}" end="{{nightDateMax || ''}}" bindchange="onStartDateChange">
        <view class="field"><text class="field-key">开始日期</text><text class="field-val">{{startDate}} ›</text></view>
      </picker>
      <picker mode="date" value="{{endDate}}" start="{{startDate}}" end="{{nightDateMax || ''}}" bindchange="onEndDateChange">
        <view class="field"><text class="field-key">结束日期</text><text class="field-val">{{endDate}} ›</text></view>
      </picker>
      <view class="hint">{{nightHint}}</view>
    </block>

    <view class="time-summary" wx:if="{{timeSummary}}">
      <text class="ts-icon">🕑</text>{{timeSummary}}
    </view>
  </view>

  <!-- 选择座位（内嵌平面图） -->
  <view class="bk-card bk-card--seat">
    <view class="bk-sec">
      <view class="bk-bar"></view><text>选择座位</text>
      <view class="seat-badge {{selectedLabel ? 'seat-badge--on' : ''}}">
        <block wx:if="{{selectedLabel}}">
          <text class="seat-badge-no">{{selectedLabel}}号</text>
          <text class="seat-badge-dot">·</text>
          <text class="seat-badge-zone">{{selectedZone}}</text>
        </block>
        <text wx:else>点选座位</text>
      </view>
    </view>

    <view class="seat-map-tip">点击编号选座 · 双指缩放</view>

    <view class="seat-legend">
      <view class="seat-legend-item"><view class="seat-dot available"></view><text>可选</text></view>
      <view class="seat-legend-item"><view class="seat-dot selected"></view><text>已选</text></view>
      <view class="seat-legend-item"><view class="seat-dot reserved"></view><text>已约</text></view>
      <view class="seat-legend-item"><view class="seat-dot occupied"></view><text>使用中</text></view>
      <view class="seat-count">
        <text class="seat-count-num">{{availableSeatCount}}</text>
        <text>座可订</text>
      </view>
    </view>

    <view class="seat-map-frame" wx:if="{{showSeatMap}}">
      <floor-plan-map
        seats="{{seats}}"
        selectedId="{{selectedId}}"
        bind:select="selectSeat"
      />
      <view class="seat-map-loading" wx:if="{{seatsLoading}}">
        <text class="seat-map-loading-text">{{seats.length ? '更新中…' : '加载中…'}}</text>
      </view>
    </view>
    <view class="seat-map-empty" wx:else>请先选择时间</view>
  </view>

  <view class="fixed-bottom-spacer"></view>

  <!-- 底部 CTA -->
  <view class="bk-bottom">
    <view class="bk-cta full {{seatId && preview && !previewLoading && preview.seat_id === seatId ? '' : 'bk-cta--disabled'}}" bindtap="goOrder">{{previewLoading ? '计算中…' : '立即预定'}}</view>
  </view>
</view>
