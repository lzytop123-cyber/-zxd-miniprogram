.page-booking {
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* ============ 门店 Hero ============ */
.bk-hero {
  position: relative;
  margin: 0;
  padding: 40rpx 36rpx 48rpx;
  background: linear-gradient(150deg, #2D6A4F 0%, #40916C 55%, #52B788 100%);
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
}

.bk-hero-orb {
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  right: -80rpx;
  top: -110rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0));
  opacity: 0.4;
}

.bk-hero-grid {
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(255, 255, 255, 0.06) 2rpx, transparent 2rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.06) 2rpx, transparent 2rpx);
  background-size: 56rpx 56rpx;
}

.bk-hero-label {
  position: relative;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.82);
  font-weight: 600;
}

.bk-hero-store {
  position: relative;
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-top: 10rpx;
  text-shadow: 0 4rpx 16rpx rgba(15, 45, 30, 0.25);
}

/* ============ 卡片 ============ */
.bk-card {
  margin: 24rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 30rpx;
  box-shadow: 0 6rpx 26rpx rgba(28, 43, 32, 0.06);
}

.bk-card:first-of-type {
  margin-top: -28rpx;
  position: relative;
  z-index: 2;
}

.bk-sec {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.bk-bar {
  width: 8rpx;
  height: 30rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #52B788, #2D6A4F);
}

.bk-sec text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1C2B20;
}

/* ============ 套餐类型 ============ */
.type-scroll {
  width: 100%;
  white-space: nowrap;
}

.type-track {
  display: flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.type-pill {
  flex-shrink: 0;
  padding: 18rpx 36rpx;
  border-radius: 40rpx;
  font-size: 27rpx;
  font-weight: 600;
  color: #5C7567;
  background: #F1F7F3;
  transition: all 0.2s ease;
}

.type-pill.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #52B788, #2D6A4F);
  box-shadow: 0 8rpx 18rpx rgba(45, 106, 79, 0.3);
}

/* ============ 字段行 ============ */
.field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 4rpx;
  border-bottom: 2rpx solid #F1F5F2;
}

.field-key {
  font-size: 28rpx;
  color: #5C7567;
  font-weight: 500;
}

.field-val {
  font-size: 30rpx;
  color: #1C2B20;
  font-weight: 600;
}

.quick-btns {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0 0;
  flex-wrap: wrap;
}

.quick-btns .chip {
  margin-right: 0;
}

.hint {
  font-size: 23rpx;
  color: #9CACA2;
  margin-top: 18rpx;
  line-height: 1.6;
}

.time-summary {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  background: linear-gradient(120deg, #EAF7EF, #F4FAF6);
  border-radius: 18rpx;
  font-size: 24rpx;
  color: #2D6A4F;
  font-weight: 500;
}

.ts-icon {
  font-size: 26rpx;
}

/* ============ 选座 ============ */
.seat-now {
  margin-left: auto;
  font-size: 24rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.legend {
  display: flex;
  align-items: center;
  gap: 22rpx;
  font-size: 22rpx;
  color: #8C9BA5;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.count {
  margin-left: auto;
  color: #52B788;
  font-weight: 600;
}

.dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
}

.dot.available {
  background: #D8F3DC;
  border-color: #52B788;
}

.dot.reserved {
  background: #FFF8E6;
  border-color: #E6A23C;
}

.dot.occupied {
  background: #ECEFF1;
  border-color: #CFD8DC;
}

.map-wrap {
  position: relative;
  width: 100%;
  /* 裁切图 647/843 = 76.75%，严格同比铺满 */
  padding-bottom: 76.75%;
  height: 0;
  border-radius: 20rpx;
  border: 2rpx solid #D8F3DC;
  overflow: hidden;
  background: #FAFCFB;
}

.map-empty {
  padding: 60rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #9CACA2;
  background: #F7FAF8;
  border-radius: 20rpx;
}

/* ============ 底部 CTA ============ */
.bk-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -6rpx 26rpx rgba(28, 43, 32, 0.1);
  z-index: 100;
}

.bk-cta {
  padding: 28rpx 0;
  text-align: center;
  background: linear-gradient(135deg, #52B788, #2D6A4F);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 800;
  border-radius: 44rpx;
  box-shadow: 0 10rpx 24rpx rgba(45, 106, 79, 0.35);
}

.bk-cta.full {
  width: 100%;
}

.bk-cta:active {
  transform: scale(0.98);
}
