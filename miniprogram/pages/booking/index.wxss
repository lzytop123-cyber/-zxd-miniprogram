.page-booking {
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* ============ 门店 Hero ============ */
.bk-hero {
  position: relative;
  margin: 0;
  padding: 40rpx 36rpx 48rpx;
  background: linear-gradient(150deg, #2D6A4F 0%, #40916C 55%, #52B788 100%);
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
}

.bk-hero-orb {
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  right: -80rpx;
  top: -110rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0));
  opacity: 0.4;
}

.bk-hero-grid {
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(255, 255, 255, 0.06) 2rpx, transparent 2rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.06) 2rpx, transparent 2rpx);
  background-size: 56rpx 56rpx;
}

.bk-hero-label {
  position: relative;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.82);
  font-weight: 600;
}

.bk-hero-store {
  position: relative;
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-top: 10rpx;
  text-shadow: 0 4rpx 16rpx rgba(15, 45, 30, 0.25);
}

/* ============ 卡片 ============ */
.bk-card {
  margin: 24rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 30rpx;
  box-shadow: 0 6rpx 26rpx rgba(28, 43, 32, 0.06);
}

.bk-card:first-of-type {
  margin-top: -28rpx;
  position: relative;
  z-index: 2;
}

.bk-sec {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.bk-bar {
  width: 8rpx;
  height: 30rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #52B788, #2D6A4F);
}

.bk-sec text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1C2B20;
}

/* ============ 套餐类型 ============ */
.bk-sec--type {
  flex-wrap: wrap;
}

.bk-sec-tag {
  margin-left: auto;
  font-size: 24rpx;
  font-weight: 600;
  color: #2D6A4F;
  padding: 6rpx 16rpx;
  background: #EAF7EF;
  border-radius: 999rpx;
}

.type-primary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.type-primary {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 24rpx 12rpx;
  border-radius: 22rpx;
  background: #F1F7F3;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.type-primary-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #3D5247;
}

.type-primary.active {
  background: linear-gradient(135deg, #52B788, #2D6A4F);
  border-color: #2D6A4F;
  box-shadow: 0 8rpx 18rpx rgba(45, 106, 79, 0.28);
}

.type-primary.active .type-primary-label {
  color: #FFFFFF;
}

.type-primary--night {
  grid-column: span 2;
}

.type-sub-row {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed #E4EDE7;
}

.type-sub {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 18rpx 8rpx;
  border-radius: 18rpx;
  background: #F8FBF9;
  border: 2rpx solid #E4EDE7;
}

.type-sub-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #5C7567;
}

.type-sub-days {
  font-size: 20rpx;
  color: #9CACA2;
}

.type-sub.active {
  background: #EAF7EF;
  border-color: #52B788;
}

.type-sub.active .type-sub-label {
  color: #2D6A4F;
}

.type-sub.active .type-sub-days {
  color: #52B788;
}

/* ============ 字段行 ============ */
.field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 4rpx;
  border-bottom: 2rpx solid #F1F5F2;
}

.field-key {
  font-size: 28rpx;
  color: #5C7567;
  font-weight: 500;
}

.field-val {
  font-size: 30rpx;
  color: #1C2B20;
  font-weight: 600;
}

.quick-btns {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0 0;
  flex-wrap: wrap;
}

.quick-btns .chip {
  margin-right: 0;
}

.hint {
  font-size: 23rpx;
  color: #9CACA2;
  margin-top: 18rpx;
  line-height: 1.6;
}

.hint--sec {
  margin-top: -8rpx;
  margin-bottom: 8rpx;
}

.time-summary {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  background: linear-gradient(120deg, #EAF7EF, #F4FAF6);
  border-radius: 18rpx;
  font-size: 24rpx;
  color: #2D6A4F;
  font-weight: 500;
}

.ts-icon {
  font-size: 26rpx;
}

/* ============ 选座 ============ */
.bk-card--seat {
  padding-bottom: 26rpx;
}

/* ============ 底部 CTA ============ */
.bk-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -6rpx 26rpx rgba(28, 43, 32, 0.1);
  z-index: 100;
}

.bk-cta {
  padding: 28rpx 0;
  text-align: center;
  background: linear-gradient(135deg, #52B788, #2D6A4F);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 800;
  border-radius: 44rpx;
  box-shadow: 0 10rpx 24rpx rgba(45, 106, 79, 0.35);
}

.bk-cta.full {
  width: 100%;
}

.bk-cta:active {
  transform: scale(0.98);
}

.bk-cta--disabled {
  opacity: 0.42;
  box-shadow: none;
}

.bk-cta--disabled:active {
  transform: none;
}

.seat-map-loading {
  position: absolute;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 20rpx;
  background: rgba(244, 250, 246, 0.45);
  pointer-events: auto;
}

.seat-map-loading-text {
  font-size: 22rpx;
  color: #2d6a4f;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 16rpx rgba(45, 106, 79, 0.12);
}
