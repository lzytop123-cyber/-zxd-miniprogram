.title { font-size: 18px; font-weight: bold; }
.tabs { white-space: nowrap; margin: 12px 0; }
.tab { display: inline-block; padding: 6px 14px; margin-right: 8px; background: #f5f5f5; border-radius: 16px; font-size: 12px; }
.tab.active { background: #FFD000; font-weight: bold; }
.label { margin: 12px 0 4px; font-weight: bold; font-size: 14px; }
.picker { padding: 10px; background: #f5f5f5; border-radius: 8px; color: #1a1a1a; }
.hint { font-size: 12px; color: #888; margin: 8px 0; }
.quick-btns { display: flex; gap: 8px; margin: 8px 0; }
.quick { padding: 6px 12px; background: #fff3c4; border-radius: 16px; font-size: 12px; }
.time-summary { background: #f9f9f9; padding: 10px; border-radius: 8px; font-size: 12px; color: #666; margin: 12px 0; }
.seat-row { display: flex; justify-content: space-between; padding: 14px 0; margin: 12px 0; border-top: 1px solid #f0f0f0; border-bottom: 1px solid #f0f0f0; }
.seat-code { color: #FFD000; font-weight: bold; }
.price { margin: 16px 0; font-size: 16px; font-weight: bold; }
.seat { display: block; font-size: 12px; color: #888; font-weight: normal; margin-top: 4px; }
