.page-report {
  min-height: 100vh;
}

/* 助手模式：固定高度，聊天区滚动 + 输入框吸底 */
.page-report.chat-mode {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ============ 顶部分段切换 ============ */
.seg-wrap {
  flex-shrink: 0;
  padding: 20rpx 24rpx 8rpx;
}

.seg {
  display: flex;
  padding: 6rpx;
  background: #E4EFE8;
  border-radius: 40rpx;
}

.seg-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #5C7567;
  border-radius: 36rpx;
  transition: all 0.2s ease;
}

.seg-item.on {
  background: #FFFFFF;
  color: #2D6A4F;
  box-shadow: 0 4rpx 14rpx rgba(28, 43, 32, 0.1);
}

/* ============ 学习报告 ============ */
.report-card {
  margin-bottom: 24rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.scope {
  font-size: 24rpx;
  color: #52B788;
  padding: 8rpx 20rpx;
  background: #D8F3DC;
  border-radius: 40rpx;
}

.my-rank {
  text-align: center;
  margin-bottom: 32rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #D8F3DC, #F4FAF6);
  border-radius: 24rpx;
}

.rank-no {
  font-size: 56rpx;
  font-weight: 700;
  color: #52B788;
}

.title-badge {
  display: inline-block;
  background: #52B788;
  color: #FFFFFF;
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  margin-top: 12rpx;
}

.stat-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
  padding: 24rpx 0;
  border-top: 2rpx solid #F4FAF6;
  border-bottom: 2rpx solid #F4FAF6;
}

.stat {
  text-align: center;
}

.num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C2B20;
}

.stat-label {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 8rpx;
}

.beat {
  text-align: center;
  color: #8C9BA5;
  font-size: 24rpx;
  margin-bottom: 32rpx;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.section-title.inner {
  padding: 0;
  margin-bottom: 16rpx;
}

.rank-item {
  display: flex;
  padding: 24rpx 16rpx;
  border-bottom: 2rpx solid #F4FAF6;
  align-items: center;
  border-radius: 16rpx;
}

.rank-item.self {
  background: #D8F3DC;
}

.rank {
  width: 64rpx;
  font-weight: 700;
  color: #52B788;
  font-size: 28rpx;
}

.name {
  flex: 1;
  color: #1C2B20;
}

.mins {
  color: #8C9BA5;
  font-size: 24rpx;
}

/* 报告页底部「问问助手」提示卡 */
.assistant-tip {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 24rpx 32rpx;
  padding: 28rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(120deg, #2D6A4F 0%, #52B788 100%);
  box-shadow: 0 10rpx 26rpx rgba(45, 106, 79, 0.22);
}

.assistant-tip:active {
  transform: scale(0.99);
}

.at-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.at-text {
  flex: 1;
  min-width: 0;
}

.at-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.at-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

.at-arrow {
  color: rgba(255, 255, 255, 0.9);
  font-size: 40rpx;
  font-weight: 700;
}

/* ============ 内嵌 AI 助手聊天 ============ */
.chat-scroll {
  flex: 1;
  min-height: 0;
}

.chat-inner {
  padding: 20rpx 24rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 26rpx;
}

.msg-row.right {
  flex-direction: row-reverse;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 30rpx;
}

.avatar.bot {
  background: linear-gradient(135deg, #52B788, #2D6A4F);
  color: #FFFFFF;
}

.bubble {
  max-width: 74%;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.55;
  border-radius: 24rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

.bubble.bot {
  background: #FFFFFF;
  color: #1C2B20;
  border-top-left-radius: 8rpx;
  box-shadow: 0 4rpx 18rpx rgba(28, 43, 32, 0.06);
}

.bubble.user {
  background: linear-gradient(135deg, #52B788, #40916C);
  color: #FFFFFF;
  border-top-right-radius: 8rpx;
}

.suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 8rpx 0 26rpx 80rpx;
}

.sug-chip {
  padding: 16rpx 26rpx;
  background: #FFFFFF;
  border: 2rpx solid #D8F3DC;
  color: #2D6A4F;
  font-size: 26rpx;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 14rpx rgba(28, 43, 32, 0.05);
}

.sug-chip:active {
  background: #D8F3DC;
}

.typing {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.typing .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #B7C9BD;
  animation: blink 1.2s infinite ease-in-out;
}

.typing .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes blink {
  0%, 80%, 100% {
    opacity: 0.3;
  }
  40% {
    opacity: 1;
  }
}

.bottom-anchor {
  height: 2rpx;
}

.chat-input-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(28, 43, 32, 0.06);
}

.chat-input {
  flex: 1;
  height: 76rpx;
  padding: 0 26rpx;
  background: #F4FAF6;
  border-radius: 38rpx;
  font-size: 28rpx;
}

.chat-send {
  flex-shrink: 0;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 36rpx;
  background: #52B788;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 38rpx;
}

.chat-send.disabled {
  background: #CFD8DC;
  color: #FFFFFF;
}
