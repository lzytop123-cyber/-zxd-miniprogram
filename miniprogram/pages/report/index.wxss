.page-report {
  min-height: 100vh;
}

.assistant-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 24rpx 32rpx;
  padding: 28rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(120deg, #2D6A4F 0%, #52B788 100%);
  box-shadow: 0 10rpx 26rpx rgba(45, 106, 79, 0.22);
}

.assistant-entry:active {
  transform: scale(0.99);
}

.ae-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.ae-text {
  flex: 1;
  min-width: 0;
}

.ae-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.ae-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

.ae-arrow {
  color: rgba(255, 255, 255, 0.9);
  font-size: 40rpx;
  font-weight: 700;
}

.report-card {
  margin-bottom: 32rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.scope {
  font-size: 24rpx;
  color: #52B788;
  padding: 8rpx 20rpx;
  background: #D8F3DC;
  border-radius: 40rpx;
}

.my-rank {
  text-align: center;
  margin-bottom: 32rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #D8F3DC, #F4FAF6);
  border-radius: 24rpx;
}

.rank-no {
  font-size: 56rpx;
  font-weight: 700;
  color: #52B788;
}

.title-badge {
  display: inline-block;
  background: #52B788;
  color: #FFFFFF;
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  margin-top: 12rpx;
}

.stat-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
  padding: 24rpx 0;
  border-top: 2rpx solid #F4FAF6;
  border-bottom: 2rpx solid #F4FAF6;
}

.stat {
  text-align: center;
}

.num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C2B20;
}

.stat-label {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 8rpx;
}

.beat {
  text-align: center;
  color: #8C9BA5;
  font-size: 24rpx;
  margin-bottom: 32rpx;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.section-title.inner {
  padding: 0;
  margin-bottom: 16rpx;
}

.rank-item {
  display: flex;
  padding: 24rpx 16rpx;
  border-bottom: 2rpx solid #F4FAF6;
  align-items: center;
  border-radius: 16rpx;
}

.rank-item.self {
  background: #D8F3DC;
}

.rank {
  width: 64rpx;
  font-weight: 700;
  color: #52B788;
  font-size: 28rpx;
}

.name {
  flex: 1;
  color: #1C2B20;
}

.mins {
  color: #8C9BA5;
  font-size: 24rpx;
}
