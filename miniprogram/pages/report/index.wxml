<view class="page-report page-safe-bottom">
  <view class="card report-card">
    <view class="header">
      <text class="header-title">学习报告</text>
      <picker mode="selector" range="{{['全平台','本店']}}" bindchange="onScopeChange">
        <view class="scope">{{scopeLabel}} ▼</view>
      </picker>
    </view>

    <view class="my-rank" wx:if="{{summary}}">
      <view class="rank-no" wx:if="{{summary.rank}}">#{{summary.rank}}</view>
      <view class="title-badge">{{summary.title}}</view>
    </view>

    <view class="stat-row" wx:if="{{summary}}">
      <view class="stat">
        <view class="num">{{summary.total_sessions}}</view>
        <view class="stat-label">次数</view>
      </view>
      <view class="stat">
        <view class="num">{{summary.total_hours}}时{{summary.total_minutes_remainder}}分</view>
        <view class="stat-label">时长</view>
      </view>
      <view class="stat">
        <view class="num">{{summary.daily_avg_minutes}}分</view>
        <view class="stat-label">日均</view>
      </view>
    </view>

    <view class="beat" wx:if="{{summary}}">超越了 {{summary.beat_percent}}% 的学员</view>

    <view class="tabs">
      <view class="chip {{days===7?'active':''}}" bindtap="setDays" data-d="7">近7日</view>
      <view class="chip {{days===30?'active':''}}" bindtap="setDays" data-d="30">近30日</view>
    </view>

    <view class="section-title inner">排行榜</view>
    <view class="rank-list">
      <view class="rank-item {{item.is_self?'self':''}}" wx:for="{{leaderboard}}" wx:key="rank">
        <text class="rank">{{item.rank === 1 ? '🏆' : item.rank}}</text>
        <text class="name">{{item.nickname}}</text>
        <text class="mins">{{item.total_minutes}}分钟</text>
      </view>
      <view class="empty" wx:if="{{!leaderboard.length}}">暂无排行数据</view>
    </view>
  </view>

  <view class="assistant-entry" bindtap="goAssistant">
    <view class="ae-icon">🌱</view>
    <view class="ae-text">
      <view class="ae-title">AI 学习助手 · 小岛</view>
      <view class="ae-sub">门店问答 · 学习规划 · 随时答疑</view>
    </view>
    <view class="ae-arrow">›</view>
  </view>
</view>
