<view class="page-report {{tab==='assistant' ? 'chat-mode' : ''}}">
  <!-- 顶部分段切换 -->
  <view class="seg-wrap">
    <view class="seg">
      <view class="seg-item {{tab==='assistant' ? 'on' : ''}}" bindtap="switchTab" data-tab="assistant">AI 助手</view>
      <view class="seg-item {{tab==='report' ? 'on' : ''}}" bindtap="switchTab" data-tab="report">学习报告</view>
    </view>
  </view>

  <!-- ============ 学习报告 ============ -->
  <view wx:if="{{tab==='report'}}" class="report-body">
    <view class="card report-card">
      <view class="header">
        <text class="header-title">学习报告</text>
        <picker mode="selector" range="{{['全平台','本店']}}" bindchange="onScopeChange">
          <view class="scope">{{scopeLabel}} ▼</view>
        </picker>
      </view>

      <view class="my-rank" wx:if="{{summary}}">
        <view class="rank-no" wx:if="{{summary.rank}}">#{{summary.rank}}</view>
        <view class="title-badge">{{summary.title}}</view>
      </view>

      <view class="stat-row" wx:if="{{summary}}">
        <view class="stat">
          <view class="num">{{summary.total_sessions}}</view>
          <view class="stat-label">次数</view>
        </view>
        <view class="stat">
          <view class="num">{{summary.total_hours}}时{{summary.total_minutes_remainder}}分</view>
          <view class="stat-label">时长</view>
        </view>
        <view class="stat">
          <view class="num">{{summary.daily_avg_minutes}}分</view>
          <view class="stat-label">日均</view>
        </view>
      </view>

      <view class="beat" wx:if="{{summary}}">超越了 {{summary.beat_percent}}% 的学员</view>

      <view class="tabs">
        <view class="chip {{days===7?'active':''}}" bindtap="setDays" data-d="7">近7日</view>
        <view class="chip {{days===30?'active':''}}" bindtap="setDays" data-d="30">近30日</view>
      </view>

      <view class="section-title inner">排行榜</view>
      <view class="rank-list">
        <view class="rank-item {{item.is_self?'self':''}}" wx:for="{{leaderboard}}" wx:key="rank">
          <text class="rank">{{item.rank === 1 ? '🏆' : item.rank}}</text>
          <text class="name">{{item.nickname}}</text>
          <text class="mins">{{item.total_minutes}}分钟</text>
        </view>
        <view class="empty" wx:if="{{!leaderboard.length}}">暂无排行数据</view>
      </view>
    </view>
  </view>

  <!-- ============ AI 助手 ============ -->
  <block wx:else>
    <scroll-view
      class="chat-scroll"
      scroll-y
      scroll-into-view="{{scrollInto}}"
      scroll-with-animation
    >
      <view class="chat-inner">
        <view class="msg-row left" wx:if="{{greeting}}">
          <view class="avatar bot">岛</view>
          <view class="bubble bot">{{greeting}}</view>
        </view>

        <view class="suggestions" wx:if="{{suggestions.length && !messages.length}}">
          <view
            class="sug-chip"
            wx:for="{{suggestions}}"
            wx:key="*this"
            data-q="{{item}}"
            bindtap="onSuggestionTap"
          >{{item}}</view>
        </view>

        <view
          wx:for="{{messages}}"
          wx:key="_id"
          class="msg-row {{item.role === 'user' ? 'right' : 'left'}}"
        >
          <view wx:if="{{item.role !== 'user'}}" class="avatar bot">岛</view>
          <view class="bubble {{item.role === 'user' ? 'user' : 'bot'}}">{{item.content}}</view>
        </view>

        <view class="msg-row left" wx:if="{{loading}}">
          <view class="avatar bot">岛</view>
          <view class="bubble bot typing">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>

        <view id="chat-bottom" class="bottom-anchor"></view>
      </view>
    </scroll-view>

    <view class="chat-input-bar">
      <input
        class="chat-input"
        value="{{draft}}"
        placeholder="问点什么吧…"
        confirm-type="send"
        bindinput="onInput"
        bindconfirm="onSend"
        disabled="{{loading}}"
      />
      <view class="chat-send {{(draft && !loading) ? '' : 'disabled'}}" bindtap="onSend">发送</view>
    </view>
  </block>
</view>
