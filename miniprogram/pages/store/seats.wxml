<view class="page-seats page-safe-bottom">
  <view class="card seat-card seat-card--premium">
    <view class="seat-head">
      <view class="seat-head-bar"></view>
      <text class="seat-head-title">选择座位</text>
    </view>
    <view class="seat-map-tip">点击编号选座 · 双指缩放</view>

    <view class="seat-legend">
      <view class="seat-legend-item"><view class="seat-dot available"></view><text>可选</text></view>
      <view class="seat-legend-item"><view class="seat-dot selected"></view><text>已选</text></view>
      <view class="seat-legend-item"><view class="seat-dot reserved"></view><text>已约</text></view>
      <view class="seat-legend-item"><view class="seat-dot occupied"></view><text>使用中</text></view>
      <view class="seat-count">
        <text class="seat-count-num">{{availableSeatCount}}</text>
        <text>/ {{planSeatCount}} 可订</text>
      </view>
    </view>

    <view class="seat-map-frame seat-map-frame--premium">
      <floor-plan-map
        seats="{{seats}}"
        selectedId="{{selectedId}}"
        bind:select="selectSeat"
      />
    </view>
  </view>

  <view class="fixed-bottom-bar seat-bottom">
    <view class="seat-selected" wx:if="{{selectedCode}}">
      已选 <text class="seat-selected-code">{{selectedLabel}}号</text>
      <text class="seat-selected-meta" wx:if="{{selectedZone}}"> · {{selectedZone}}</text>
    </view>
    <view class="seat-selected seat-selected--ph" wx:else>请选座</view>
    <view class="btn-primary {{selectedCode ? '' : 'disabled'}}" bindtap="confirm">下一步</view>
  </view>
</view>
