.page-seats {
  min-height: 100vh;
  padding-bottom: 220rpx;
}

.seat-card {
  margin-bottom: 0;
  padding: 28rpx 24rpx 24rpx;
}

.page-head {
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.page-sub {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 6rpx;
}

.legend {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  margin-bottom: 16rpx;
  align-items: center;
  flex-wrap: wrap;
  color: #8C9BA5;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.count {
  margin-left: auto;
  color: #52B788;
  font-weight: 600;
}

.dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
}

.dot.available {
  background: #D8F3DC;
  border-color: #52B788;
}

.dot.reserved {
  background: #FFF8E6;
  border-color: #E6A23C;
}

.dot.occupied {
  background: #ECEFF1;
  border-color: #CFD8DC;
}

.map-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 96.68%;
  height: 0;
  border-radius: 20rpx;
  border: 2rpx solid #D8F3DC;
  overflow: hidden;
  background: #FAFCFB;
}

.selected {
  text-align: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #1C2B20;
}

.selected.placeholder {
  color: #8C9BA5;
}

.selected-code {
  font-weight: 700;
  color: #52B788;
  font-size: 32rpx;
}

.selected-meta {
  color: #8C9BA5;
  font-size: 24rpx;
}

.fixed-bottom-bar .btn-primary {
  margin: 0;
  width: 100%;
}
