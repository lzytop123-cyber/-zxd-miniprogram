.page-seats {
  min-height: 100vh;
  padding-bottom: 220rpx;
}

.seat-card {
  margin-bottom: 0;
  padding: 28rpx 24rpx 24rpx;
}

.seat-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 8rpx;
}

.seat-head-bar {
  width: 8rpx;
  height: 30rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #52B788, #2D6A4F);
}

.seat-head-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1C2B20;
}

.seat-selected {
  text-align: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #1C2B20;
}

.seat-selected--ph {
  color: #8C9BA5;
}

.seat-selected-code {
  font-weight: 800;
  color: #2D6A4F;
  font-size: 32rpx;
}

.seat-selected-meta {
  color: #8C9BA5;
  font-size: 24rpx;
}

.seat-bottom .btn-primary {
  margin: 0;
  width: 100%;
  background: linear-gradient(135deg, #52B788, #2D6A4F);
}
