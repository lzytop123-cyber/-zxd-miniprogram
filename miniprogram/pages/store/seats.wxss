.page-seats {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4fbf6 0%, #eef8f1 100%);
}

.seat-card--premium {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(247, 251, 248, 0.98));
  border: 1rpx solid rgba(99, 147, 114, 0.1);
  box-shadow: 0 14rpx 36rpx rgba(61, 101, 78, 0.08);
}

.seat-card--premium::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 18% 12%, rgba(84, 179, 129, 0.08), transparent 20%),
    radial-gradient(circle at 84% 10%, rgba(123, 188, 145, 0.06), transparent 18%);
  pointer-events: none;
}

.seat-card--premium .seat-head,
.seat-card--premium .seat-map-tip,
.seat-card--premium .seat-legend,
.seat-card--premium .seat-map-frame--premium {
  position: relative;
  z-index: 1;
}

.seat-head-title {
  font-size: 30rpx;
}

.seat-map-tip {
  color: rgba(65, 92, 76, 0.72);
  font-size: 20rpx;
  line-height: 1.45;
}

.seat-legend {
  gap: 10rpx;
}

.seat-legend-item,
.seat-count {
  font-size: 20rpx;
}

.seat-map-frame--premium {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.65), rgba(241, 247, 243, 0.94));
  border: 1rpx solid rgba(104, 150, 118, 0.1);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}
