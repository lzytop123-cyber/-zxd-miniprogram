.page-assistant {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F4FAF6;
}

.chat-scroll {
  flex: 1;
  min-height: 0;
}

.chat-inner {
  padding: 28rpx 24rpx;
}

/* 消息行 */
.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 26rpx;
}

.msg-row.right {
  flex-direction: row-reverse;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 30rpx;
}

.avatar.bot {
  background: linear-gradient(135deg, #52B788, #2D6A4F);
  color: #FFFFFF;
}

.bubble {
  max-width: 74%;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.55;
  border-radius: 24rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

.bubble.bot {
  background: #FFFFFF;
  color: #1C2B20;
  border-top-left-radius: 8rpx;
  box-shadow: 0 4rpx 18rpx rgba(28, 43, 32, 0.06);
}

.bubble.user {
  background: linear-gradient(135deg, #52B788, #40916C);
  color: #FFFFFF;
  border-top-right-radius: 8rpx;
}

/* 推荐问题 */
.suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 8rpx 0 26rpx 80rpx;
}

.sug-chip {
  padding: 16rpx 26rpx;
  background: #FFFFFF;
  border: 2rpx solid #D8F3DC;
  color: #2D6A4F;
  font-size: 26rpx;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 14rpx rgba(28, 43, 32, 0.05);
}

.sug-chip:active {
  background: #D8F3DC;
}

/* 思考中三点 */
.typing {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.typing .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #B7C9BD;
  animation: blink 1.2s infinite ease-in-out;
}

.typing .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes blink {
  0%, 80%, 100% {
    opacity: 0.3;
  }
  40% {
    opacity: 1;
  }
}

.bottom-anchor {
  height: 2rpx;
}

/* 输入区 */
.input-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(28, 43, 32, 0.06);
}

.input {
  flex: 1;
  height: 76rpx;
  padding: 0 26rpx;
  background: #F4FAF6;
  border-radius: 38rpx;
  font-size: 28rpx;
}

.send-btn {
  flex-shrink: 0;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 36rpx;
  background: #52B788;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 38rpx;
}

.send-btn.disabled {
  background: #CFD8DC;
  color: #FFFFFF;
}
