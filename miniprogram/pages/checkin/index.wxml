<view class="page-checkin page-safe-bottom">
  <view wx:if="{{pageLoading}}" class="skeleton-checkin-wrap">
    <view class="card skeleton-checkin-card">
      <view class="skeleton-line skeleton-line--lg skeleton-shimmer" style="margin: 0 auto 24rpx;"></view>
      <view class="skeleton-checkin-ring skeleton-shimmer"></view>
      <view class="skeleton-line skeleton-shimmer"></view>
      <view class="skeleton-line skeleton-line--sm skeleton-shimmer" style="margin: 0 auto;"></view>
    </view>
  </view>

  <view wx:elif="{{!reservation}}" class="empty card empty-card">
    <view class="empty-icon">📚</view>
    <view class="empty-text">暂无进行中的订单</view>
    <view class="empty-hint">预约成功后到店开门即可，无需手动签到</view>
    <view class="btn-primary" bindtap="goBooking">立即预定</view>
  </view>

  <view wx:else class="active-panel">
    <view class="hero card">
      <view class="hero-header">
        <view class="hero-header-main">
          <view class="hero-title">{{reservation.store_name}}</view>
          <view class="hero-subtitle">正在使用中 · 到店后可直接开门</view>
        </view>
        <view class="hero-badge" wx:if="{{statusLabel}}">{{statusLabel}}</view>
      </view>

      <view class="seat-ring">
        <view class="seat-no">{{reservation.seat_code}}</view>
        <view class="seat-label">您的座位</view>
      </view>

      <view class="hero-grid">
        <view class="hero-meta-item">
          <view class="hero-meta-label">结束时间</view>
          <view class="hero-meta-value">{{endDisplay}}</view>
        </view>
        <view class="hero-meta-item hero-meta-item--accent">
          <view class="hero-meta-label">剩余时长</view>
          <view class="hero-meta-value hero-meta-value--accent">{{countdown}}</view>
        </view>
      </view>

      <view class="hero-footer" wx:if="{{statusHint}}">{{statusHint}}</view>
    </view>

    <view class="order-switch card" wx:if="{{activeList.length > 1}}">
      <view class="order-switch-head">
        <view class="order-switch-label">切换订单</view>
        <view class="order-switch-count">{{activeList.length}} 个进行中</view>
      </view>
      <view class="order-switch-list">
        <view
          class="order-chip {{selectedId === item.id ? 'active' : ''}}"
          wx:for="{{activeList}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="selectReservation"
        >
          <view class="order-chip-seat">{{item.seat_code}}</view>
          <view class="order-chip-meta">{{item.store_name}}</view>
        </view>
      </view>
    </view>

    <view class="open-section card">
      <view class="open-status-wrap">
        <view class="tip ended" wx:if="{{countdown === '已结束'}}">订单已结束，无法开门</view>
        <view class="tip" wx:elif="{{!canOpen}}">{{openWindowHint}}</view>
        <view class="tip ok" wx:elif="{{canOpen}}">已可开门，请站在门口操作</view>
      </view>

      <view class="tip warn" wx:if="{{lastOpenError}}">{{lastOpenError}}</view>

      <view
        class="open-hero {{canOpen && pluginReady && !opening ? '' : 'disabled'}}"
        bindtap="openDoorBle"
      >
        <view class="open-hero-icon">📶</view>
        <view class="open-hero-text">{{opening ? '开门中…' : '蓝牙开门'}}</view>
        <view class="open-hero-sub" wx:if="{{!pluginReady}}">{{pluginHint || '插件未加载'}}</view>
        <view class="open-hero-sub" wx:elif="{{canOpen && pluginReady}}">开启手机蓝牙并靠近门锁</view>
        <view class="open-hero-sub" wx:elif="{{!canOpen}}">到时间后按钮自动可用</view>
      </view>

      <view class="action-row">
        <view class="btn-outline" bindtap="checkout" wx:if="{{reservation.status === 1}}">提前离座</view>
      </view>
    </view>
  </view>
</view>
