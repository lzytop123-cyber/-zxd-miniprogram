<view class="page-checkin page-safe-bottom">
  <view wx:if="{{!reservation}}" class="empty card empty-card">
    <view class="empty-icon">📚</view>
    <view class="empty-text">暂无进行中的订单</view>
    <view class="empty-hint">预约成功后到店开门即可，无需手动签到</view>
    <view class="btn-primary" bindtap="goBooking">立即预定</view>
  </view>

  <view wx:else class="active-panel">
    <view class="info-card card">
      <view class="store-name">{{reservation.store_name}}</view>
      <view class="seat-ring">
        <view class="seat-no">{{reservation.seat_code}}</view>
        <view class="seat-label">您的座位</view>
      </view>
      <view class="time">结束 {{endDisplay}}</view>
      <view class="status-pill" wx:if="{{statusLabel}}">{{statusLabel}}</view>
      <view class="status-hint" wx:if="{{statusHint}}">{{statusHint}}</view>
      <view class="countdown" wx:if="{{countdown}}">{{countdown}}</view>
    </view>

    <view class="open-section">
      <view class="tip" wx:if="{{!canOpen}}">提前 15 分钟可开门</view>
      <view class="tip ok" wx:elif="{{canOpen}}">已可开门，请站在门口操作</view>

      <view
        class="open-hero {{canOpen && pluginReady && !opening ? '' : 'disabled'}}"
        bindtap="openDoorBle"
      >
        <view class="open-hero-icon">📶</view>
        <view class="open-hero-text">{{opening ? '开门中…' : '蓝牙开门'}}</view>
        <view class="open-hero-sub" wx:if="{{!pluginReady}}">{{pluginHint || '插件未加载'}}</view>
        <view class="open-hero-sub" wx:elif="{{canOpen && pluginReady}}">开启手机蓝牙并靠近门锁</view>
        <view class="open-hero-sub" wx:elif="{{!canOpen}}">到时间后按钮自动可用</view>
      </view>

      <view class="open-steps" wx:if="{{canOpen && pluginReady}}">
        <text>① 打开蓝牙</text>
        <text class="dot">·</text>
        <text>② 靠近门锁</text>
        <text class="dot">·</text>
        <text>③ 点击上方按钮</text>
      </view>
    </view>

    <view class="footer-actions">
      <view class="btn-outline" bindtap="checkout" wx:if="{{reservation.status === 1}}">提前离座</view>
    </view>
  </view>
</view>
