page {
  width: 100%;
  overflow-x: hidden;
}

.page-checkin,
.page-checkin view,
.page-checkin scroll-view {
  box-sizing: border-box;
}

.page-checkin {
  min-height: 100vh;
  padding: 24rpx;
  overflow-x: hidden;
  max-width: 100vw;
}

.page-checkin .card {
  margin: 0;
  width: 100%;
}

.empty-card {
  text-align: center;
  padding: 92rpx 32rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C2B20;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-bottom: 40rpx;
}

.active-panel {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  min-height: calc(100vh - 48rpx - env(safe-area-inset-bottom));
  overflow-x: hidden;
}

.hero {
  box-sizing: border-box;
  padding: 30rpx 24rpx 28rpx;
  overflow: hidden;
}

.hero-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.hero-header-main {
  flex: 1;
  min-width: 0;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C2B20;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8C9BA5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #D8F3DC;
  color: #2D6A4F;
  font-size: 22rpx;
  font-weight: 600;
}

.seat-ring {
  width: 288rpx;
  height: 288rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EAF7EF 0%, #F4FAF6 100%);
  border: 8rpx solid rgba(82, 183, 136, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(82, 183, 136, 0.18);
  overflow: hidden;
}

.seat-no {
  font-size: 78rpx;
  font-weight: 800;
  color: #2D6A4F;
  line-height: 1;
}

.seat-label {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 12rpx;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 8rpx;
}

.hero-meta-item {
  min-width: 0;
  padding: 20rpx 18rpx;
  border-radius: 20rpx;
  background: #F4FAF6;
}

.hero-meta-item--accent {
  background: #ECF9F0;
}

.hero-meta-label {
  font-size: 22rpx;
  color: #8C9BA5;
  margin-bottom: 8rpx;
}

.hero-meta-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C2B20;
  line-height: 1.35;
  word-break: break-all;
}

.hero-meta-value--accent {
  color: #2D6A4F;
}

.hero-footer {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #8C9BA5;
  text-align: center;
  line-height: 1.5;
}

.order-switch {
  padding: 18rpx 24rpx 20rpx;
  overflow: hidden;
}

.order-switch-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.order-switch-label {
  font-size: 24rpx;
  color: #1C2B20;
  font-weight: 600;
}

.order-switch-count {
  font-size: 22rpx;
  color: #8C9BA5;
  flex-shrink: 0;
}

.order-switch-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  max-width: 100%;
}

.order-chip {
  min-width: 0;
  max-width: 100%;
  padding: 18rpx 16rpx;
  border-radius: 18rpx;
  background: #F8FBF9;
  border: 2rpx solid rgba(82, 183, 136, 0.08);
  text-align: center;
  box-sizing: border-box;
  overflow: hidden;
  transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
}

.order-chip:active {
  transform: scale(0.98);
}

.order-chip.active {
  background: linear-gradient(180deg, #D8F3DC 0%, #EEF9F1 100%);
  border-color: rgba(82, 183, 136, 0.55);
  box-shadow: 0 8rpx 20rpx rgba(82, 183, 136, 0.12);
}

.order-chip-seat {
  font-size: 30rpx;
  font-weight: 800;
  color: #2D6A4F;
  line-height: 1.2;
}

.order-chip-meta {
  font-size: 22rpx;
  color: #8C9BA5;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@media screen and (min-width: 430px) {
  .order-switch-list {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

.open-section {
  padding: 24rpx 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.open-status-wrap {
  padding: 0 4rpx;
}

.tip {
  text-align: center;
  font-size: 24rpx;
  color: #8C9BA5;
  line-height: 1.45;
}

.tip.ok {
  color: #52B788;
  font-weight: 600;
}

.tip.ended {
  color: #c45c5c;
  font-weight: 600;
}

.tip.warn {
  color: #8A6D3B;
  background: var(--color-warning-bg);
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: left;
}

.open-btn {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 22rpx 22rpx 20rpx;
  border-radius: 22rpx;
  background: #F4FAF6;
  border: 2rpx solid rgba(82, 183, 136, 0.16);
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.open-btn--active {
  background: linear-gradient(135deg, #52B788 0%, #40916C 100%);
  border-color: transparent;
  box-shadow: 0 10rpx 28rpx rgba(82, 183, 136, 0.22);
}

.open-btn--active:active {
  transform: scale(0.985);
  opacity: 0.94;
}

.open-btn--disabled {
  background: #F3F5F4;
  border-color: #E8ECEA;
  box-shadow: none;
}

.open-btn-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.open-btn--disabled .open-btn-icon-wrap {
  background: #ECEFF1;
}

.open-btn-icon {
  font-size: 36rpx;
  line-height: 1;
}

.open-btn-main {
  flex: 1;
  min-width: 0;
}

.open-btn-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
}

.open-btn--disabled .open-btn-title {
  color: #8C9BA5;
}

.open-btn-desc {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.86);
  line-height: 1.4;
}

.open-btn--disabled .open-btn-desc {
  color: #A8B5AD;
}

.open-btn-chevron {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1;
  flex-shrink: 0;
  margin-top: -2rpx;
}

.open-btn--disabled .open-btn-chevron {
  color: #C5CDCA;
}

.open-footer {
  display: flex;
  justify-content: center;
  padding-top: 4rpx;
}

.checkout-link {
  font-size: 26rpx;
  color: #8C9BA5;
  padding: 10rpx 20rpx;
  text-decoration: underline;
  text-underline-offset: 6rpx;
}

.checkout-link:active {
  color: #2D6A4F;
}

.checkout-hint {
  font-size: 22rpx;
  color: #B0BEC5;
  text-align: center;
  line-height: 1.5;
}

.skeleton-checkin-wrap {
  padding: 0;
}

