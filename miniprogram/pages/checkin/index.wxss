page {
  width: 100%;
  overflow-x: hidden;
}

.page-checkin,
.page-checkin view,
.page-checkin scroll-view {
  box-sizing: border-box;
}

.page-checkin {
  min-height: 100vh;
  padding: 24rpx;
  overflow-x: hidden;
  max-width: 100vw;
}

.empty-card {
  text-align: center;
  padding: 92rpx 32rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C2B20;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-bottom: 40rpx;
}

.active-panel {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  min-height: calc(100vh - 48rpx - env(safe-area-inset-bottom));
  overflow-x: hidden;
}

.hero {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  padding: 30rpx 24rpx 28rpx;
  overflow: hidden;
}

.hero-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.hero-header-main {
  flex: 1;
  min-width: 0;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C2B20;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8C9BA5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #D8F3DC;
  color: #2D6A4F;
  font-size: 22rpx;
  font-weight: 600;
}

.seat-ring {
  width: 288rpx;
  height: 288rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EAF7EF 0%, #F4FAF6 100%);
  border: 8rpx solid rgba(82, 183, 136, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(82, 183, 136, 0.18);
  overflow: hidden;
}

.seat-no {
  font-size: 78rpx;
  font-weight: 800;
  color: #2D6A4F;
  line-height: 1;
}

.seat-label {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 12rpx;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 8rpx;
}

.hero-meta-item {
  min-width: 0;
  padding: 20rpx 18rpx;
  border-radius: 20rpx;
  background: #F4FAF6;
}

.hero-meta-item--accent {
  background: #ECF9F0;
}

.hero-meta-label {
  font-size: 22rpx;
  color: #8C9BA5;
  margin-bottom: 8rpx;
}

.hero-meta-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C2B20;
  line-height: 1.35;
  word-break: break-all;
}

.hero-meta-value--accent {
  color: #2D6A4F;
}

.hero-footer {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #8C9BA5;
  text-align: center;
  line-height: 1.5;
}

.order-switch {
  padding: 18rpx 20rpx 20rpx;
  overflow: hidden;
}

.order-switch-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.order-switch-label {
  font-size: 24rpx;
  color: #1C2B20;
  font-weight: 600;
}

.order-switch-count {
  font-size: 22rpx;
  color: #8C9BA5;
  flex-shrink: 0;
}

.order-switch-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  max-width: 100%;
}

.order-chip {
  min-width: 0;
  max-width: 100%;
  padding: 18rpx 16rpx;
  border-radius: 18rpx;
  background: #F8FBF9;
  border: 2rpx solid rgba(82, 183, 136, 0.08);
  text-align: center;
  box-sizing: border-box;
  overflow: hidden;
  transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
}

.order-chip:active {
  transform: scale(0.98);
}

.order-chip.active {
  background: linear-gradient(180deg, #D8F3DC 0%, #EEF9F1 100%);
  border-color: rgba(82, 183, 136, 0.55);
  box-shadow: 0 8rpx 20rpx rgba(82, 183, 136, 0.12);
}

.order-chip-seat {
  font-size: 30rpx;
  font-weight: 800;
  color: #2D6A4F;
  line-height: 1.2;
}

.order-chip-meta {
  font-size: 22rpx;
  color: #8C9BA5;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@media screen and (min-width: 430px) {
  .order-switch-list {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

.open-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.open-status-wrap {
  padding: 2rpx 0 0;
}

.tip {
  text-align: center;
  font-size: 26rpx;
  color: #8C9BA5;
  line-height: 1.4;
}

.tip.ok {
  color: #52B788;
  font-weight: 600;
}

.tip.ended {
  color: #c45c5c;
  font-weight: 600;
}

.tip.warn {
  color: #8A6D3B;
  background: var(--color-warning-bg);
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: left;
}

.open-hero {
  width: 100%;
  padding: 52rpx 28rpx 48rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  background: linear-gradient(145deg, #52B788, #2D6A4F);
  box-shadow: 0 18rpx 42rpx rgba(82, 183, 136, 0.28);
}

.open-hero:active:not(.disabled) {
  opacity: 0.92;
  transform: scale(0.985);
}

.open-hero.disabled {
  background: #ECEFF1;
  box-shadow: none;
}

.open-hero-icon {
  font-size: 60rpx;
  line-height: 1;
}

.open-hero-text {
  color: #FFFFFF;
  font-size: 38rpx;
  font-weight: 700;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

.open-hero-sub {
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  margin-top: 10rpx;
  text-align: center;
  line-height: 1.5;
  padding: 0 18rpx;
}

.open-hero.disabled .open-hero-text,
.open-hero.disabled .open-hero-sub {
  color: #8C9BA5;
}

.action-row {
  display: flex;
  justify-content: center;
}

.action-row .btn-outline {
  width: 100%;
  margin-top: 0;
}

.skeleton-checkin-wrap {
  padding: 24rpx 0;
}

