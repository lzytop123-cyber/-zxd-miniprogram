.page-checkin {
  min-height: 100vh;
  padding: 24rpx;
}

.empty-card {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C2B20;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-bottom: 40rpx;
}

.active-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-card {
  width: 100%;
  box-sizing: border-box;
  text-align: center;
  margin: 0 0 32rpx;
}

.store-name {
  font-size: 28rpx;
  color: #8C9BA5;
  margin-bottom: 32rpx;
}

.seat-ring {
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto 32rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D8F3DC, #F4FAF6);
  border: 6rpx solid #52B788;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(82, 183, 136, 0.2);
}

.seat-no {
  font-size: 72rpx;
  font-weight: 700;
  color: #2D6A4F;
  line-height: 1;
}

.seat-label {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 12rpx;
}

.time {
  font-size: 26rpx;
  color: #1C2B20;
}

.countdown {
  font-size: 36rpx;
  font-weight: 700;
  color: #52B788;
  margin-top: 16rpx;
}

.lock-name {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 12rpx;
}

.open-section {
  width: 100%;
  margin-bottom: 32rpx;
}

.tip {
  text-align: center;
  font-size: 24rpx;
  color: #8C9BA5;
  margin-bottom: 20rpx;
}

.tip.ok {
  color: #52B788;
}

.open-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.open-btn {
  width: 280rpx;
  padding: 36rpx 16rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.open-btn.ble {
  background: linear-gradient(145deg, #52B788, #2D6A4F);
  box-shadow: 0 12rpx 32rpx rgba(82, 183, 136, 0.35);
}

.open-btn.remote {
  background: linear-gradient(145deg, #409EFF, #2D6A4F);
  box-shadow: 0 12rpx 32rpx rgba(64, 158, 255, 0.25);
}

.open-btn:active:not(.disabled) {
  opacity: 0.92;
  transform: scale(0.98);
}

.open-btn.disabled {
  background: #ECEFF1;
  box-shadow: none;
}

.open-btn.disabled .open-text,
.open-btn.disabled .open-sub {
  color: #8C9BA5;
}

.open-icon {
  font-size: 48rpx;
}

.open-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

.open-sub {
  color: rgba(255, 255, 255, 0.85);
  font-size: 20rpx;
  margin-top: 4rpx;
}

.hint {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #F4FAF6;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #8C9BA5;
  line-height: 1.5;
}

.page-checkin .btn-outline {
  width: 90%;
}
