.page-checkin {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.empty-card {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C2B20;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-bottom: 40rpx;
}

.active-panel {
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 48rpx - env(safe-area-inset-bottom));
}

.order-switch {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
}

.order-switch-label {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-bottom: 16rpx;
}

.order-switch-scroll {
  width: 100%;
}

.order-switch-inner {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.order-chip {
  flex-shrink: 0;
  min-width: 160rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  background: #F4FAF6;
  border: 2rpx solid transparent;
  text-align: center;
}

.order-chip.active {
  background: #D8F3DC;
  border-color: #52B788;
}

.order-chip-seat {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D6A4F;
  line-height: 1.2;
}

.order-chip-meta {
  font-size: 22rpx;
  color: #8C9BA5;
  margin-top: 6rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-card {
  width: 100%;
  box-sizing: border-box;
  text-align: center;
  margin: 0 0 24rpx;
}

.store-name {
  font-size: 28rpx;
  color: #8C9BA5;
  margin-bottom: 28rpx;
}

.seat-ring {
  width: 300rpx;
  height: 300rpx;
  margin: 0 auto 28rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D8F3DC, #F4FAF6);
  border: 6rpx solid #52B788;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(82, 183, 136, 0.2);
}

.seat-no {
  font-size: 72rpx;
  font-weight: 700;
  color: #2D6A4F;
  line-height: 1;
}

.seat-label {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 12rpx;
}

.time {
  font-size: 26rpx;
  color: #1C2B20;
}

.status-pill {
  display: inline-block;
  margin-top: 16rpx;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: #D8F3DC;
  color: #2D6A4F;
  font-size: 24rpx;
  font-weight: 600;
}

.status-hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8C9BA5;
  line-height: 1.5;
}

.countdown {
  font-size: 36rpx;
  font-weight: 700;
  color: #52B788;
  margin-top: 16rpx;
}

.open-section {
  width: 100%;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 8rpx 0 24rpx;
}

.tip {
  text-align: center;
  font-size: 26rpx;
  color: #8C9BA5;
  margin-bottom: 24rpx;
}

.tip.ok {
  color: #52B788;
  font-weight: 600;
}

.tip.ended {
  color: #c45c5c;
  font-weight: 600;
}

.open-hero {
  width: 100%;
  padding: 48rpx 32rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  background: linear-gradient(145deg, #52B788, #2D6A4F);
  box-shadow: 0 16rpx 40rpx rgba(82, 183, 136, 0.35);
}

.open-hero:active:not(.disabled) {
  opacity: 0.92;
  transform: scale(0.985);
}

.open-hero.disabled {
  background: #ECEFF1;
  box-shadow: none;
}

.open-hero-icon {
  font-size: 56rpx;
  line-height: 1;
}

.open-hero-text {
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

.open-hero-sub {
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  margin-top: 12rpx;
  text-align: center;
  line-height: 1.5;
  padding: 0 16rpx;
}

.open-hero.disabled .open-hero-text,
.open-hero.disabled .open-hero-sub {
  color: #8C9BA5;
}

.open-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #F4FAF6;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #5C6B63;
}

.open-steps .dot {
  color: #C5D4CC;
}

.footer-actions {
  width: 100%;
  padding-top: 8rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.page-checkin .btn-outline {
  width: 100%;
}
