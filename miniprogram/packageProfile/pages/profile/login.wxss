.page-login {
  min-height: 100vh;
  background: #F4FAF6;
}

.welcome {
  min-height: 100vh;
  padding: 120rpx 48rpx 80rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.welcome-brand {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 80rpx;
}

.welcome-mark {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  margin-bottom: 36rpx;
}

.welcome-island {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  top: 36rpx;
  height: 52rpx;
  background: #1C2B20;
  border-radius: 40rpx 40rpx 18rpx 18rpx;
  clip-path: polygon(8% 70%, 22% 28%, 48% 8%, 72% 30%, 92% 68%, 100% 78%, 0 78%);
}

.welcome-wave {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  height: 6rpx;
  background: #1C2B20;
  border-radius: 6rpx;
  opacity: 0.85;
}

.welcome-wave--1 { bottom: 48rpx; }
.welcome-wave--2 { bottom: 34rpx; width: 70%; left: 15%; opacity: 0.55; }
.welcome-wave--3 { bottom: 20rpx; width: 45%; left: 27.5%; opacity: 0.35; }

.welcome-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #1C2B20;
  letter-spacing: 2rpx;
}

.welcome-en {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8C9BA5;
  letter-spacing: 3rpx;
}

.welcome-actions {
  width: 100%;
}

.welcome-main {
  text-align: center;
}

.welcome-phone-btn {
  width: 100%;
  margin: 0;
  padding: 0;
  line-height: 88rpx;
  border: none;
  font-size: 30rpx;
}

.welcome-phone-btn::after {
  border: none;
}

.welcome-main.disabled {
  opacity: 0.45;
}

.welcome-secondary {
  margin-top: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1C2B20;
  background: #FFFFFF;
  border: 2rpx solid #D5DED8;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.welcome-secondary-btn {
  width: 100%;
  margin: 24rpx 0 0;
  padding: 0;
  background: #FFFFFF;
  color: #1C2B20;
  border: 2rpx solid #D5DED8;
  font-size: 30rpx;
  font-weight: 600;
}

.welcome-secondary-btn::after {
  border: none;
}

.welcome-secondary.disabled {
  opacity: 0.4;
  color: #8C9BA5;
}

.welcome-links {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
}

.welcome-skip {
  text-align: center;
  font-size: 26rpx;
  color: #8C9BA5;
}

.welcome-agree {
  margin-top: 48rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.agree-box {
  width: 28rpx;
  height: 28rpx;
  margin-top: 4rpx;
  border: 2rpx solid #B7C4BC;
  border-radius: 50%;
  flex-shrink: 0;
  box-sizing: border-box;
}

.agree-box.checked {
  border-color: #2D6A4F;
  background: #2D6A4F;
  box-shadow: inset 0 0 0 6rpx #F4FAF6;
}

.agree-text {
  flex: 1;
  font-size: 22rpx;
  color: #8C9BA5;
  line-height: 1.6;
}

.agree-link {
  color: #2D6A4F;
}

.login-loading {
  padding: 120rpx 32rpx;
  text-align: center;
}

.login-loading .login-logo {
  margin-bottom: 32rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #8C9BA5;
}

.login-panel {
  margin: 48rpx 32rpx 0;
  text-align: center;
}

.login-logo {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto;
  border-radius: 32rpx;
  background: linear-gradient(160deg, #2D6A4F 0%, #52B788 100%);
  color: #fff;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 120rpx;
}

.login-title {
  margin-top: 32rpx;
  font-size: 40rpx;
  font-weight: 800;
  color: #1C2B20;
}

.login-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8C9BA5;
  line-height: 1.6;
}

.login-error {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #E07A5F;
}

.login-btn {
  margin-top: 48rpx;
}

.login-note {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #8C9BA5;
}

.setup-card {
  margin: 24rpx 32rpx 0;
  text-align: center;
}

.setup-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1C2B20;
}

.setup-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8C9BA5;
  line-height: 1.5;
}

.avatar-picker {
  margin: 32rpx auto 0;
  padding: 0;
  background: transparent;
  line-height: normal;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: visible;
}

.avatar-picker .avatar {
  display: block;
}

.avatar-picker::after {
  border: none;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid #52B788;
  background: #D8F3DC;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.avatar-placeholder--add {
  box-sizing: border-box;
  border-style: dashed;
  background: #F4FAF6;
  font-size: 64rpx;
  font-weight: 300;
  color: #52B788;
}

.avatar-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #52B788;
  text-align: center;
  padding: 0 24rpx;
  line-height: 1.5;
}

.nickname-field,
.goal-field {
  margin-top: 28rpx;
  text-align: left;
}

.field-label {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-bottom: 12rpx;
}

.nickname-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #F4FAF6;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1C2B20;
}

.goal-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.goal-chip {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #2D6A4F;
  background: #E8F5E9;
}

.goal-chip.active {
  background: #2D6A4F;
  color: #fff;
}

.setup-save {
  margin-top: 32rpx;
}

.setup-note {
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #8C9BA5;
}

.loading-cancel {
  margin-top: 40rpx;
  display: block;
  text-align: center;
}
