<view class="page-login page-safe-bottom">
  <view class="login-loading" wx:if="{{step === 'loading'}}">
    <view class="login-logo">岛</view>
    <view class="loading-text">正在登录...</view>
  </view>

  <view class="login-panel card" wx:elif="{{step === 'error'}}">
    <view class="login-logo">岛</view>
    <view class="login-title">登录失败</view>
    <view class="login-error" wx:if="{{loginError}}">{{loginError}}</view>
    <view class="btn-primary login-btn" bindtap="retryLogin">重试</view>
  </view>

  <view class="setup-card card" wx:elif="{{step === 'setup' && user}}">
    <view class="setup-title">设置学员资料</view>
    <view class="setup-desc">选择头像和昵称，即可预约自习</view>

    <button class="avatar-picker" hover-class="none" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image
        wx:if="{{avatarDisplay}}"
        class="avatar"
        src="{{avatarDisplay}}"
        mode="aspectFill"
      />
      <view wx:else class="avatar avatar-placeholder avatar-placeholder--add">+</view>
      <view class="avatar-tip">{{avatarUploading ? '同步中…' : '点击选择微信头像'}}</view>
    </button>

    <view class="nickname-field">
      <view class="field-label">昵称</view>
      <input
        type="nickname"
        class="nickname-input"
        placeholder="输入昵称"
        value="{{draftNickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>

    <view class="goal-field">
      <view class="field-label">备考方向（选填）</view>
      <view class="goal-chips">
        <view
          wx:for="{{goalOptions}}"
          wx:key="value"
          class="goal-chip {{draftStudyGoal === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onGoalSelect"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="btn-primary setup-save" bindtap="saveProfile">开始使用</view>
    <view class="setup-note">学号 #{{user.id}}</view>
  </view>
</view>
