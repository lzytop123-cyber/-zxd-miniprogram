<view class="page-login page-safe-bottom">
  <view class="welcome" wx:if="{{step === 'welcome'}}">
    <view class="welcome-brand">
      <view class="welcome-mark">
        <view class="welcome-island"></view>
        <view class="welcome-wave welcome-wave--1"></view>
        <view class="welcome-wave welcome-wave--2"></view>
        <view class="welcome-wave welcome-wave--3"></view>
      </view>
      <view class="welcome-name">知行岛·自习室</view>
      <view class="welcome-en">ZHIXINGDAO · ZIXISHI</view>
    </view>

    <view class="welcome-actions">
      <button
        wx:if="{{agreed}}"
        class="btn-primary welcome-main welcome-phone-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="onPhoneLogin"
        hover-class="none"
        loading="{{phoneLogging}}"
        disabled="{{phoneLogging}}"
      >{{phoneBtnText}}</button>
      <view wx:else class="btn-primary welcome-main disabled" bindtap="onNeedAgree">{{phoneBtnText}}</view>

      <button
        wx:if="{{agreed}}"
        class="welcome-secondary welcome-phone-btn welcome-secondary-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="onPhoneLogin"
        hover-class="none"
        loading="{{phoneLogging}}"
        disabled="{{phoneLogging}}"
      >一键快捷登录/注册</button>
      <view wx:else class="welcome-secondary disabled" bindtap="onNeedAgree">一键快捷登录/注册</view>

      <view class="welcome-links">
        <text class="welcome-skip" bindtap="onSkipLogin">取消 / 暂不登录</text>
      </view>
    </view>

    <view class="welcome-agree" bindtap="toggleAgree">
      <view class="agree-box {{agreed ? 'checked' : ''}}"></view>
      <view class="agree-text">
        我已阅读并同意
        <text class="agree-link" catchtap="openAgreement" data-type="user">《用户协议》</text>
        <text class="agree-link" catchtap="openAgreement" data-type="privacy">《隐私协议》</text>
      </view>
    </view>
  </view>

  <view class="login-loading" wx:elif="{{step === 'loading'}}">
    <view class="login-logo">岛</view>
    <view class="loading-text">正在登录...</view>
    <view class="welcome-skip loading-cancel" bindtap="onCancelLoading">取消</view>
  </view>

  <view class="login-panel card" wx:elif="{{step === 'error'}}">
    <view class="login-logo">岛</view>
    <view class="login-title">登录失败</view>
    <view class="login-error" wx:if="{{loginError}}">{{loginError}}</view>
    <view class="btn-primary login-btn" bindtap="retryLogin">重试</view>
    <view class="welcome-skip" bindtap="onSkipLogin">取消 / 暂不登录</view>
  </view>

  <view class="setup-card card" wx:elif="{{step === 'setup' && user}}">
    <view class="setup-title">设置学员资料</view>
    <view class="setup-desc">选择头像和昵称，即可预约自习</view>

    <button
      class="avatar-picker"
      hover-class="none"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
      disabled="{{avatarUploading}}"
    >
      <image
        wx:if="{{avatarDisplay}}"
        class="avatar"
        src="{{avatarDisplay}}"
        mode="aspectFill"
      />
      <view wx:else class="avatar avatar-placeholder avatar-placeholder--add">+</view>
    </button>
    <view class="avatar-tip" wx:if="{{avatarUploading}}">同步中…</view>
    <view class="avatar-tip" wx:else bindtap="pickAvatarFromAlbum">点击上方选择微信头像，或从相册选择</view>
    <view class="avatar-album-btn" bindtap="pickAvatarFromAlbum">从相册上传头像</view>

    <view class="nickname-field">
      <view class="field-label">昵称</view>
      <input
        type="nickname"
        class="nickname-input"
        placeholder="输入昵称"
        value="{{draftNickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>

    <view class="goal-field">
      <view class="field-label">备考方向（选填）</view>
      <view class="goal-chips">
        <view
          wx:for="{{goalOptions}}"
          wx:key="value"
          class="goal-chip {{draftStudyGoal === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onGoalSelect"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="btn-primary setup-save" bindtap="saveProfile">开始使用</view>
    <view class="setup-skip" bindtap="onSkipSetup">稍后再说，先逛逛</view>
    <view class="setup-note">学号 #{{user.id}}</view>
  </view>
</view>
