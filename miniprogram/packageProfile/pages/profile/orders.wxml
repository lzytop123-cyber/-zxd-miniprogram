<view class="orders-page page-safe-bottom">
  <view class="order-card card" wx:for="{{orders}}" wx:key="id">
    <view class="order-head">
      <view class="order-store">{{item.store_name}}</view>
      <view class="order-status status-{{item.statusTone}}">{{item.statusLabel}}</view>
    </view>

    <view class="order-tags">
      <view class="tag tag-usage">{{item.usageLabel}}</view>
      <view class="tag tag-zone zone-{{item.zoneTone}}" wx:if="{{item.zoneName}}">{{item.zoneName}}</view>
    </view>

    <view class="order-meta">
      <view class="meta-row">
        <text class="meta-label">座位</text>
        <text class="meta-value">{{item.seatLine}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-label">来源</text>
        <text class="meta-value source-{{item.sourceTone}}">{{item.paySourceLabel}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-label">时间</text>
        <text class="meta-value">{{item.timeRange}}</text>
      </view>
      <view class="meta-row">
        <text class="meta-label">金额</text>
        <text class="meta-value meta-price">{{item.priceText}}</text>
      </view>
    </view>

    <view class="order-hint" wx:if="{{item.statusHint}}">{{item.statusHint}}</view>

    <view class="order-action" wx:if="{{item.canOpen}}">
      <view class="action-btn" catchtap="goOpen" data-id="{{item.id}}">去开门</view>
    </view>
    <view class="order-action" wx:if="{{item.canPay}}">
      <view class="action-btn ghost" catchtap="cancelOrder" data-id="{{item.id}}">取消</view>
      <view class="action-btn" catchtap="goPay" data-id="{{item.id}}">去支付</view>
    </view>
  </view>

  <view class="orders-tip card" wx:if="{{orders.length}}">
    到店开门即可
  </view>

  <view class="empty card" wx:if="{{!orders.length}}">
    <view class="empty-icon">📋</view>
    <view>暂无订单</view>
  </view>
</view>
