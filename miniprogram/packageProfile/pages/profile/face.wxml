<view class="list-page page-safe-bottom">
  <view class="card">
    <view class="face-status {{registered ? 'done' : ''}}">
      <view class="face-icon">{{registered ? '✅' : '👤'}}</view>
      <view class="status">{{registered ? '已录入人脸' : '尚未录入人脸'}}</view>
    </view>
    <view class="hint">录入后可用于门禁通行</view>
    <view class="btn-primary" bindtap="chooseFace">{{registered ? '重新录入' : '拍照录入'}}</view>
  </view>
</view>
