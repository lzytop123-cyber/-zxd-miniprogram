.list-page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.list-card {
  margin-bottom: 24rpx;
}

.list-card .name,
.order .row:first-child {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.list-card .info,
.order .sub {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 8rpx;
  line-height: 1.5;
}

.order .row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.order .status {
  font-size: 24rpx;
  color: #52B788;
  font-weight: 600;
}

/* 优惠券 */
.coupon-item {
  position: relative;
  border-left: 8rpx solid #52B788;
  margin-bottom: 24rpx;
}

.coupon-item .name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.coupon-item .info {
  font-size: 24rpx;
  color: #8C9BA5;
  margin-top: 8rpx;
}

.coupon-item .status {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
  background: #D8F3DC;
  color: #2D6A4F;
}

/* 钱包 */
.wallet-hero {
  background: linear-gradient(135deg, #52B788 0%, #2D6A4F 100%);
  color: #FFFFFF;
  margin: 24rpx;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(45, 106, 79, 0.25);
}

.wallet-hero .balance-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.wallet-hero .balance-val {
  font-size: 56rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.amounts {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 24rpx 0;
}

.amt {
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  border: 2rpx solid #D8F3DC;
  color: #2D6A4F;
  font-size: 28rpx;
  font-weight: 600;
}

.amt.active {
  background: #52B788;
  border-color: #52B788;
  color: #FFFFFF;
}

.section-head {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D6A4F;
  margin-bottom: 16rpx;
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 24rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D6A4F;
  background: #E8F5E9;
}

.action-btn.primary {
  background: #52B788;
  color: #fff;
}

.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8C9BA5;
}

.log {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F4FAF6;
}

.log:last-child {
  border-bottom: none;
}

.log-amt,
.pts {
  font-size: 30rpx;
  font-weight: 700;
  color: #52B788;
}

.log .time {
  font-size: 22rpx;
  color: #8C9BA5;
  margin-top: 4rpx;
}

/* 积分 */
.points-hero {
  text-align: center;
  padding: 16rpx 0 32rpx;
  border-bottom: 2rpx solid #F4FAF6;
  margin-bottom: 16rpx;
}

.points-hero .total {
  font-size: 56rpx;
  font-weight: 700;
  color: #52B788;
}

.points-hero .total-label {
  font-size: 26rpx;
  color: #8C9BA5;
  margin-top: 8rpx;
}

/* 邀请 */
.code-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F4FAF6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 0;
}

.code {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D6A4F;
  letter-spacing: 4rpx;
}

.copy-btn {
  padding: 12rpx 28rpx;
  background: #52B788;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 24rpx;
}

.input {
  background: #F4FAF6;
  border: 2rpx solid #D8F3DC;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 0;
  font-size: 28rpx;
}

/* 人脸 */
.face-status {
  text-align: center;
  padding: 32rpx 0;
}

.face-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.face-status .status {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D6A4F;
}

.face-status.done .status {
  color: #52B788;
}

/* ============ 我的期限卡页 ============ */
.cards-page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.cards-hero {
  margin: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #2D6A4F 0%, #40916C 52%, #52B788 100%);
  box-shadow: 0 16rpx 40rpx rgba(45, 106, 79, 0.22);
  color: #fff;
}

.hero-main {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.hero-count {
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1;
}

.hero-label {
  font-size: 28rpx;
  opacity: 0.92;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.hero-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
}

.hero-btn.primary {
  background: #fff;
  color: #2D6A4F;
}

.cards-list {
  padding: 0 24rpx;
}

.ticket-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  padding: 28rpx 32rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2D6A4F 0%, #40916C 58%, #52B788 100%);
  color: #fff;
  box-shadow: 0 12rpx 32rpx rgba(45, 106, 79, 0.2);
}

.ticket-deco {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 10rpx,
    rgba(255, 255, 255, 0.05) 10rpx,
    rgba(255, 255, 255, 0.05) 20rpx
  );
  pointer-events: none;
}

.ticket-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ticket-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
}

.ticket-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #2D6A4F;
  font-weight: 600;
}

.ticket-name {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
  padding-right: 80rpx;
}

.ticket-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.88;
  line-height: 1.5;
}

.ticket-meta.highlight {
  font-size: 26rpx;
  font-weight: 600;
  opacity: 1;
}

.ticket-rule {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed rgba(255, 255, 255, 0.25);
  font-size: 22rpx;
  opacity: 0.82;
  line-height: 1.5;
}

.cards-empty {
  margin: 24rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: var(--shadow-card);
}

.cards-empty .empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D6A4F;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8C9BA5;
  line-height: 1.6;
}

.empty-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.empty-btn {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #E8F5E9;
  color: #2D6A4F;
}

.empty-btn.primary {
  background: #52B788;
  color: #fff;
}
