.orders-page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.order-card {
  margin-bottom: 24rpx;
}

.order-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-store {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #2D6A4F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.status-active {
  background: #D8F3DC;
  color: #2D6A4F;
}

.status-booked {
  background: #E3F2FD;
  color: #1565C0;
}

.status-warn {
  background: #FFF8E6;
  color: #8A6D3B;
}

.status-done {
  background: #F4FAF6;
  color: #8C9BA5;
}

.status-muted {
  background: #ECEFF1;
  color: #8C9BA5;
}

.order-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.tag-usage {
  background: #E8F5E9;
  color: #2D6A4F;
}

.tag-zone {
  background: #F4FAF6;
  color: #5A6B62;
}

.zone-immersion {
  background: #EDE7F6;
  color: #5E35B1;
}

.zone-workspace {
  background: #E3F2FD;
  color: #1565C0;
}

.zone-standard {
  background: #FFF3E0;
  color: #E65100;
}

.order-meta {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #F8FBF9;
  border-radius: 16rpx;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.meta-row + .meta-row {
  margin-top: 10rpx;
}

.meta-label {
  flex-shrink: 0;
  width: 72rpx;
  color: #8C9BA5;
}

.meta-value {
  flex: 1;
  min-width: 0;
  color: #2D3436;
  word-break: break-all;
}

.meta-price {
  font-weight: 700;
  color: #2D6A4F;
}

.source-meituan {
  color: #E65100;
  font-weight: 600;
}

.source-douyin {
  color: #111;
  font-weight: 600;
}

.source-wechat {
  color: #07C160;
  font-weight: 600;
}

.source-balance {
  color: #1565C0;
  font-weight: 600;
}

.source-card {
  color: #2D6A4F;
  font-weight: 600;
}

.source-pending {
  color: #8A6D3B;
  font-weight: 600;
}

.order-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #52B788;
  line-height: 1.5;
}

.order-action {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F4FAF6;
}

.action-btn {
  display: inline-block;
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  background: #52B788;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.action-btn.ghost {
  background: #fff;
  color: #8C9BA5;
  border: 2rpx solid #E3E8E5;
}

.orders-tip {
  font-size: 24rpx;
  color: #8C9BA5;
  line-height: 1.6;
  text-align: center;
}
