<view class="cards-page page-safe-bottom">
  <view class="cards-hero">
    <view class="hero-main">
      <view class="hero-count">{{activeCount}}</view>
      <view class="hero-label">可用期限卡</view>
    </view>
    <view class="hero-actions">
      <view class="hero-btn primary" bindtap="goBuy">直接购买</view>
      <view class="hero-btn" bindtap="goExchange">团购验券</view>
    </view>
  </view>

  <view class="cards-list" wx:if="{{cards.length}}">
    <view class="ticket-card ticket-{{item.card_type}}" wx:for="{{cards}}" wx:key="id">
      <view class="ticket-deco"></view>
      <view class="ticket-top">
        <view class="ticket-type">{{item.typeLabel}}</view>
        <view class="ticket-badge">可用</view>
      </view>
      <view class="ticket-name">{{item.card_name || item.typeLabel}}</view>
      <view class="ticket-meta" wx:if="{{item.validityRangeText}}">
        <text>效期 {{item.validityRangeText}}</text>
        <text class="ticket-remain {{item.validityRemainUrgent ? 'urgent' : ''}}" wx:if="{{item.validityRemainText}}"> · {{item.validityRemainText}}</text>
      </view>
      <view class="ticket-meta" wx:elif="{{item.validityText}}">{{item.validityText}}</view>
      <view class="ticket-meta highlight" wx:if="{{item.remainText}}">{{item.remainText}}</view>
      <view class="ticket-rule" wx:if="{{item.ruleText}}">{{item.ruleText}}</view>
    </view>
  </view>

  <view class="cards-empty" wx:else>
    <view class="empty-icon">🎫</view>
    <view class="empty-title">暂无期限卡</view>
    <view class="empty-desc">购买或验券后在此查看</view>
    <view class="empty-actions">
      <view class="empty-btn primary" bindtap="goBuy">去购买</view>
      <view class="empty-btn" bindtap="goExchange">验券兑换</view>
    </view>
  </view>
</view>
