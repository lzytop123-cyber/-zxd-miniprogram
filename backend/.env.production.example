# 复制为 backend/.env 并填写真实值（切勿提交 Git）

APP_ENV=production
# 小程序/商户审核中设为 true：未填 WX 时仍允许 dev 登录与 mock-pay；审核通过后改 false
PRE_WECHAT_LAUNCH=true
SECRET_KEY=请替换为64位随机字符串
BASE_URL=https://api.your-domain.com

DATABASE_URL=mysql+pymysql://zxd:你的密码@mysql:3306/zxd_study?charset=utf8mb4
REDIS_URL=redis://redis:6379/0

# 微信小程序（公众平台 → 开发 → 开发管理）
WX_APPID=wxXXXXXXXXXXXXXXXX
WX_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 微信支付 v3（商户平台 → 账户中心 → API 安全）
WX_PAY_MCHID=1234567890
WX_PAY_SERIAL_NO=证书序列号
WX_PAY_API_V3_KEY=32位APIv3密钥
WX_PAY_CERT_PATH=./certs/apiclient_cert.pem
WX_PAY_KEY_PATH=./certs/apiclient_key.pem

# 通通锁开放平台
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=
TTLOCK_USERNAME=
TTLOCK_PASSWORD=

# 云老板团购核销（美团/抖音）
MEITUAN_BASE_URL=https://openapi.yunlaoban.vip
MEITUAN_PLATFORM=1
MEITUAN_SHOP_ID=
MEITUAN_CLIENT_ID=
MEITUAN_SECRET=
MEITUAN_TIMEOUT=60000
COUPON_PROVIDER=meituan

# 后台管理员（生产请改强密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置强密码
