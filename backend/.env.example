# App
APP_ENV=development
# 生产环境必须改为 ≥16 位随机强密钥（python -c "import secrets;print(secrets.token_urlsafe(32))"）
SECRET_KEY=change-me-in-production
BASE_URL=http://127.0.0.1:8002

# CORS 允许来源：开发用 *；生产必须配置域名白名单（逗号分隔），否则启动会被拒绝
# 例：CORS_ORIGINS=https://admin.example.com,https://www.example.com
CORS_ORIGINS=*

# 微信/商户审核期可置 true（生产仍放开 dev 登录 + mock 支付），审核通过后务必改回 false
PRE_WECHAT_LAUNCH=false
# 小程序「学习助手」：审核期 false 隐藏 Tab；通过后 true 并重启后端即可
FEATURE_STUDY_ASSISTANT=true

# 生产环境请复制 backend/.env.production.example → .env
# 完整上线步骤见 docs/DEPLOY.md

# Database
DATABASE_URL=sqlite:///./zxd_study.db
# MySQL (production): mysql+pymysql://zxd:zxd123@localhost:3306/zxd_study?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# WeChat Mini Program
WX_APPID=your_wx_appid
WX_APP_SECRET=your_wx_app_secret

# WeChat Pay (v3)
WX_PAY_MCHID=
WX_PAY_SERIAL_NO=
WX_PAY_API_V3_KEY=
WX_PAY_CERT_PATH=./certs/apiclient_cert.pem
WX_PAY_KEY_PATH=./certs/apiclient_key.pem
# 公钥模式必填（否则购卡报 PUB_KEY_ID_ 错误）
WX_PAY_PUBLIC_KEY_PATH=./cert/pub_key.pem
WX_PAY_PUBLIC_KEY_ID=

# TTLock / Sciener（见 docs/TTLOCK.md）
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=
TTLOCK_USERNAME=
TTLOCK_PASSWORD=
# 仅 WiFi 网关锁可开；纯蓝牙锁保持 false
TTLOCK_REMOTE_UNLOCK_ENABLED=false

# Yunlaoban / 云老板团购核销（YUNLAOBAN_* 与 MEITUAN_* 二选一命名均可）
MEITUAN_BASE_URL=https://openapi.yunlaoban.vip
MEITUAN_PLATFORM=1
MEITUAN_SHOP_ID=
MEITUAN_CLIENT_ID=
MEITUAN_SECRET=
MEITUAN_TIMEOUT=60000
# mock=始终Mock | meituan=真实核销 | auto=有凭证走真实否则Mock
COUPON_PROVIDER=auto

# 抖音官方团购核销（platform=2；official=仅抖音走官方，yunlaoban=抖音仍走云老板，auto=有凭证走官方）
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_POI_ID=
DOUYIN_COUPON_PROVIDER=auto

# Admin (dev only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# DeepSeek AI 学习助手（https://platform.deepseek.com 申请 Key）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# AI 知识库 RAG（ChromaDB 向量检索，数据目录 backend/data/chroma）
KNOWLEDGE_RAG_ENABLED=true
KNOWLEDGE_RAG_TOP_K=5
KNOWLEDGE_CHUNK_SIZE=600
KNOWLEDGE_CHUNK_OVERLAP=80
